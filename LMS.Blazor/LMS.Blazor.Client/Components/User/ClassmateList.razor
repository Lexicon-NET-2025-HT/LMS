@using LMS.Shared.DTOs.User
@inject IUserService UserService
@using BlazorBlueprint.Components

<BbCard Class="@Class">
    <BbCardHeader Class="flex flex-row items-center justify-between space-y-0 pb-3">
        <BbCardTitle Class="text-sm font-semibold">
            <i class="bi bi-people me-2"></i>@Title
        </BbCardTitle>
        @if (!isLoading && classmates.Count > 0)
        {
            <BbBadge Variant="BadgeVariant.Secondary">@classmates.Count</BbBadge>
        }
    </BbCardHeader>

    <BbCardContent Class="p-0">

        @if (isLoading)
        {
            <div class="px-3 py-2 space-y-3">
                @for (int i = 0; i < SkeletonCount; i++)
                {
                    <div class="flex items-center gap-3">
                        <BbSkeleton Class="h-8 w-8 rounded-full flex-shrink-0" />
                        <div class="flex-1 space-y-1">
                            <BbSkeleton Class="h-3 w-3/4" />
                            <BbSkeleton Class="h-3 w-1/2" />
                        </div>
                    </div>
                }
            </div>
        }

        else if (loadError is not null)
        {
            <div class="px-3 py-3">
                <BbAlert Variant="AlertVariant.Danger" Class="mb-0">
                    <BbAlertDescription>@loadError</BbAlertDescription>
                </BbAlert>
            </div>
        }

        else if (!classmates.Any())
        {
            <p class="text-muted px-3 py-3 text-sm mb-0">No other students enrolled yet.</p>
        }

        else
        {
            var visible = classmates.Take(MaxVisible).ToList();
            var overflow = classmates.Count - visible.Count;

            <BbScrollArea Class="max-h-[340px]">
                <div class="divide-y">
                    @foreach (var mate in visible)
                    {
                        <div class="flex items-center gap-3 px-3 py-2">

                            <BbAvatar Class="h-8 w-8 flex-shrink-0">
                                <BbAvatarFallback Class="bg-primary/10 text-primary text-xs font-semibold">
                                    @GetInitials(mate.Name)
                                </BbAvatarFallback>
                            </BbAvatar>

                            <div class="flex-1 overflow-hidden">
                                <p class="text-sm font-semibold truncate mb-0">@mate.Name</p>
                                <p class="text-xs text-muted-foreground truncate mb-0">@mate.Email</p>
                            </div>
                        </div>
                    }

                    @if (overflow > 0)
                    {
                        <p class="text-xs text-muted-foreground text-center py-2 mb-0">
                            +@overflow more student@(overflow > 1 ? "s" : "")
                        </p>
                    }
                </div>
            </BbScrollArea>
        }

    </BbCardContent>
</BbCard>

@code {
    /// <summary>The course whose enrolled students to display.</summary>
    [Parameter, EditorRequired]
    public int CourseId { get; set; }

    /// <summary>Card title text.</summary>
    [Parameter]
    public string Title { get; set; } = "Classmates";

    /// <summary>Maximum rows to render before showing an overflow count.</summary>
    [Parameter]
    public int MaxVisible { get; set; } = 10;

    /// <summary>Number of skeleton rows shown while loading.</summary>
    [Parameter]
    public int SkeletonCount { get; set; } = 4;

    /// <summary>Extra CSS classes forwarded to the root BbCard.</summary>
    [Parameter]
    public string? Class { get; set; }

    private List<StudentDto> classmates = [];
    private bool isLoading;
    private string? loadError;

    protected override async Task OnParametersSetAsync()
    {
        // Re-fetch whenever CourseId changes (e.g. component reused in a loop).
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        if (CourseId <= 0)
            return;

        isLoading = true;
        loadError = null;
        StateHasChanged();

        try
        {
            var result = await UserService.GetUsersByCourseAsync(CourseId);
            classmates = result ?? [];
        }
        catch (Exception ex)
        {
            loadError = $"Could not load classmates. {ex.Message}";
            classmates = [];
        }
        finally
        {
            isLoading = false;
        }
    }

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "?";

        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : parts[0][0].ToString().ToUpper();
    }
}
