@using BlazorBlueprint.Primitives.Table
@using LMS.Shared.DTOs.Activity
@* @rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false)) *@

<BbTable TData="ActivityDto" Data="Activities">
    <BbTableHeader>
        <BbTableRow TData="ActivityDto">
            <BbTableHeaderCell TData="ActivityDto">Name</BbTableHeaderCell>
            <BbTableHeaderCell TData="ActivityDto">Description</BbTableHeaderCell>
            <BbTableHeaderCell TData="ActivityDto">Start</BbTableHeaderCell>
            <BbTableHeaderCell TData="ActivityDto">End</BbTableHeaderCell>
        </BbTableRow>
    </BbTableHeader>
    <BbTableBody>
        @foreach (var activity in Activities)
        {
            <BbTableRow TData="ActivityDto">
                <BbTableCell> @activity.Name </BbTableCell>
                <BbTableCell> @activity.Description </BbTableCell>
                <BbTableCell> @activity.StartTime </BbTableCell>
                <BbTableCell> @activity.EndTime </BbTableCell>
            </BbTableRow>
        }
    </BbTableBody>
</BbTable>

@code {
    [Parameter, EditorRequired]
    public List<ActivityDto> Activities { get; set; } = [];
}