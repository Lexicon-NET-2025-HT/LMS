@using LMS.Shared.DTOs.Common
@using LMS.Shared.DTOs.User
@using LMS.Shared.DTOs.Course
@using LMS.Shared.DTOs.AuthDtos
@using System.ComponentModel.DataAnnotations
@inject IApiService ApiService

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">@(isEditMode ? "Edit User" : "Create User")</h5>
    </div>
    <div class="card-body">

        @foreach (var errorMessage in errorMessages)
        {
            <div class="alert alert-danger alert-dismissible">
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessages.Remove(errorMessage)"></button>
            </div>
        }

        <EditForm Model="model" OnValidSubmit="HandleValidSubmitAsync">
            <DataAnnotationsValidator />

            @* ---- Name ---- *@
            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Username <span class="text-danger">*</span>
                </label>
                <InputText class="form-control" @bind-Value="model.UserName" placeholder="Username" />
                <ValidationMessage For="() => model.UserName" class="text-danger small" />
            </div>

            @* ---- Email ---- *@
            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Email <span class="text-danger">*</span>
                </label>
                <InputText class="form-control" @bind-Value="model.Email" placeholder="user@example.com" />
                <ValidationMessage For="() => model.Email" class="text-danger small" />
            </div>

            @* ---- Password (create only) ---- *@
            @if (!isEditMode)
            {
                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        Password <span class="text-danger">*</span>
                    </label>
                    <InputText type="password" class="form-control" @bind-Value="model.Password" placeholder="Password" />
                    <ValidationMessage For="() => model.Password" class="text-danger small" />
                </div>
            }

            @* ---- Role ---- *@
            <div class="mb-3">
                <label class="form-label fw-semibold">Role</label>
                <InputSelect class="form-select" @bind-Value="model.Role">
                    <option value="">-- Select Role --</option>
                    <option value="Student">Student</option>
                    <option value="Teacher">Teacher</option>
                </InputSelect>
                <ValidationMessage For="() => model.Role" class="text-danger small" />
            </div>

            @* ---- Course (hidden for teachers) ---- *@
            @if (model.Role != "Teacher")
            {
                <div class="mb-3">
                    <label class="form-label fw-semibold">Course</label>
                    <InputSelect class="form-select" @bind-Value="model.CourseId">
                        <option value="">-- No Course --</option>
                        @if (courses != null)
                        {
                            @foreach (var course in courses)
                            {
                                <option value="@course.Id">@course.Name (#@course.Id)</option>
                            }
                        }
                    </InputSelect>
                    <ValidationMessage For="() => model.CourseId" class="text-danger small" />
                </div>
            }

            @* ---- Actions ---- *@
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    @(isEditMode ? "Update User" : "Create User")
                </button>
                <button type="button" class="btn btn-secondary"
                        @onclick="OnCancel" disabled="@isSubmitting">
                    Cancel
                </button>
            </div>

        </EditForm>
    </div>
</div>

@code {
    [Parameter]
    public UserDto? User { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<UserDto> OnSubmit { get; set; }

    [Parameter, EditorRequired]
    public EventCallback OnCancel { get; set; }

    private UserFormModel model = new();
    private bool isEditMode;
    private bool isSubmitting;
    List<string> errorMessages = new List<string>();

    private IEnumerable<CourseDto>? courses;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await ApiService.GetAsync<PagedResultDto<CourseDto>>("api/courses?page=1&pageSize=9999");
            if (result is not null) courses = result.Items;
        }
        catch (Exception ex)
        {
            errorMessages.Add($"Failed to load courses. {ex.Message}");
        }
    }

    protected override void OnParametersSet()
    {
        isEditMode = User is not null;

        model = isEditMode
            ? new UserFormModel
            {
                UserName = User!.Name,
                Email = User.Email,
                Role = User.Role,
                CourseId = User.CourseId
            }
            : new UserFormModel();
    }

    private async Task HandleValidSubmitAsync()
    {
        isSubmitting = true;
        errorMessages.Clear();

        try
        {
            if (isEditMode)
            {
                // PUT api/users/{id} — role + course only
                var updateDto = new UpdateUserDto
                {
                    Role = model.Role,
                    Name = model.UserName,
                    Email = model.Email,
                    CourseId = model.CourseId
                };

                var updated = await ApiService.PutAsync<UserDto>($"api/users/{User!.Id}", updateDto);
                if (updated is not null)
                    await OnSubmit.InvokeAsync(updated);
                else
                    errorMessages.Add("Failed to update user. Please try again.");
            }
            else
            {
                // POST api/users
                var createDto = new CreateUserDto
                {
                    Role = model?.Role,
                    Name = model.UserName,
                    Password = model.Password,
                    Email = model.Email,
                    CourseId = model.CourseId
                };
                var result = await ApiService.PostAsync<UserDto>($"api/users", createDto);
                await OnSubmit.InvokeAsync(result);
            }

        }
        catch (HttpRequestException ex)
        {
            if(ex.Data == null || ex.Data.Count == 0) errorMessages.Add($"An error occurred: {ex.Message}");
            else foreach (object key in ex.Data.Keys) errorMessages.Add($"{ex.Data[key]}");
        }
        catch (Exception ex)
        {
            errorMessages.Add($"An error occurred: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    // ---- Internal form model ----
    private class UserFormModel
    {
        [Required(ErrorMessage = "Username is required.")]
        [MaxLength(200, ErrorMessage = "Username cannot exceed 200 characters.")]
        public string UserName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email is required.")]
        [MaxLength(254, ErrorMessage = "Email cannot exceed 254 characters.")]
        [EmailAddress]
        public string Email { get; set; } = string.Empty;

        [MaxLength(100)]
        [DataType(DataType.Password)]
        public string Password { get; set; } = string.Empty;

        public string? Role { get; set; }

        public int? CourseId { get; set; }
    }
}
