@using LMS.Shared.DTOs.Module
@using BlazorBlueprint.Icons.Lucide.Components
@using BlazorBlueprint.Icons.Lucide.Data

<div style="border-radius:12px;overflow:hidden;height:100%;display:flex;flex-direction:column;">
    <BbCard Class="h-100">

        <div style="height:120px;background:@Gradient;display:flex;align-items:center;
            justify-content:center;position:relative;">
            <LucideIcon Name="@(string.IsNullOrEmpty(Module.Icon) ? GetIcon(Module.Name) : Module.Icon)" Size="48" Style="color:rgba(255,255,255,0.85);" />

            <div style="position:absolute;top:12px;right:12px;">
                <BbBadge Variant="@Status.Variant">@Status.Label</BbBadge>
            </div>

            @if (IsTeacher)
            {
                <div style="position:absolute;top:12px;left:12px;">
                    <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Small"
                              Style="background:rgba(0,0,0,0.25);color:white;border-radius:6px;"
                              OnClick="@(() => OnCycleGradient.InvokeAsync(Module.Id))">🎨</BbButton>
                </div>
            }
        </div>

        <BbCardContent Class="p-4">
            <h5 class="fw-semibold mb-1" style="font-size:1rem;">@Module.Name</h5>
            <p class="text-muted mb-0" style="font-size:0.78rem;">
                @Module.StartDate.ToString("MMM dd") – @(Module.EndDate?.ToString("MMM dd") ?? "TBD")
            </p>
            <BbSeparator Class="my-3" />
            <p class="text-muted" style="font-size:0.85rem;overflow:hidden;display:-webkit-box;
            -webkit-line-clamp:2;-webkit-box-orient:vertical;">@Module.Description</p>

            @if (Status.Label == "Active" && Module.EndDate.HasValue)
            {
                var pct = GetProgress();
                <div class="mt-3">
                    <div class="d-flex justify-content-between mb-1" style="font-size:0.75rem;color:#888;">
                        <span>Progress</span><span>@pct%</span>
                    </div>
                    <div style="height:6px;background:#e9ecef;border-radius:99px;overflow:hidden;">
                        <div style="width:@pct%;height:100%;background:@Gradient;
                        border-radius:99px;transition:width 0.4s;"></div>
                    </div>
                </div>
            }
        </BbCardContent>

        <BbCardFooter Class="px-4 pb-4 pt-0 d-flex justify-content-between align-items-center">
            <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small"
                      OnClick="@(() => OnViewActivities.InvokeAsync(Module.Id))">
                Activities
                <BbBadge Variant="BadgeVariant.Secondary" Class="ms-1">@Module.ActivityCount</BbBadge>
            </BbButton>
            @if (IsTeacher)
            {
                <div class="d-flex gap-2">
                    <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Small"
                              OnClick="@(() => OnEdit.InvokeAsync(Module))">✏️</BbButton>
                    <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Small"
                              Style="color:var(--bb-destructive);"
                              OnClick="@(() => OnDelete.InvokeAsync(Module.Id))">🗑️</BbButton>
                </div>
            }
        </BbCardFooter>

    </BbCard>
</div>

@code {
    [Parameter, EditorRequired] public ModuleDto Module { get; set; } = default!;
    [Parameter] public bool IsTeacher { get; set; }
    [Parameter] public string Gradient { get; set; } = "";
    [Parameter] public EventCallback<int> OnCycleGradient { get; set; }
    [Parameter] public EventCallback<ModuleDto> OnEdit { get; set; }
    [Parameter] public EventCallback<int> OnDelete { get; set; }
    [Parameter] public EventCallback<int> OnViewActivities { get; set; }

    private (string Label, BadgeVariant Variant) Status => DateTime.Now switch
    {
        var n when Module.EndDate.HasValue && Module.EndDate < n => ("Completed", BadgeVariant.Secondary),
        var n when Module.StartDate > n => ("Upcoming", BadgeVariant.Outline),
        _ => ("Active", BadgeVariant.Default),
    };

    private int GetProgress()
    {
        var total = (Module.EndDate!.Value - Module.StartDate).TotalDays;
        var elapsed = (DateTime.Now - Module.StartDate).TotalDays;
        return (int)Math.Clamp(elapsed / total * 100, 0, 100);
    }

    private static string GetIcon(string name) => name.ToLower() switch
    {
        var n when n.Contains("database") || n.Contains("entity") => "database",
        var n when n.Contains("api") => "plug",
        var n when n.Contains("intro") || n.Contains(".net") => "rocket",
        var n when n.Contains("c#") || n.Contains("fundament") => "layers",
        var n when n.Contains("security") || n.Contains("auth") => "shield",
        var n when n.Contains("test") => "flask-conical",
        _ => "book-open",
    };
}