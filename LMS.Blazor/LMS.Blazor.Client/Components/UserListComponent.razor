@using LMS.Shared.DTOs.User

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Role</th>
                <th>Email</th>
                <th>Course</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Users)
            {
                <tr>
                    <td>@user.Name</td>
                    <td>@user.Role</td>
                    <td class="text-truncate" style="max-width: 300px;">@user.Email</td>
                    <td>@user.CourseName</td>
                    <td class="text-center">
                        <button class="btn btn-sm btn-outline-primary me-1"
                                @onclick="() => OnEdit.InvokeAsync(user)">
                            <i class="bi bi-pencil me-1"></i>Edit
                        </button>
                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="() => OnDelete.InvokeAsync(user)">
                            <i class="bi bi-trash me-1"></i>Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired]
    public List<UserDto> Users { get; set; } = [];

    [Parameter, EditorRequired]
    public EventCallback<UserDto> OnEdit { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<UserDto> OnDelete { get; set; }

}
