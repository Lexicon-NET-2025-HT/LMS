@using LMS.Shared.DTOs.Course
@using LMS.Shared.DTOs.Module
@inject ICourseService CourseService
@inject IModuleService ModuleService

<div class="card mb-3">
    <div class="card-body py-3">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-md-4">
                <label class="form-label small fw-semibold mb-1">Course</label>
                <select class="form-select"
                        value="@SelectedCourseId"
                        @onchange="HandleCourseChanged">
                    <option value="0">All Courses</option>
                    @foreach (var course in courses)
                    {
                        <option value="@course.Id">@course.Name</option>
                    }
                </select>
            </div>

            <div class="col-12 col-md-4">
                <label class="form-label small fw-semibold mb-1">Module</label>
                <select class="form-select"
                        value="@SelectedModuleId"
                        @onchange="HandleModuleChanged"
                        disabled="@(SelectedCourseId == 0)">
                    <option value="0">All Modules</option>
                    @foreach (var module in modules)
                    {
                        <option value="@module.Id">@module.Name</option>
                    }
                </select>
            </div>

            <div class="col-auto">
                <button class="btn btn-outline-secondary" @onclick="ClearFilters">
                    <i class="bi bi-x-lg me-1"></i>Clear
                </button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(loadError))
        {
            <div class="alert alert-danger mt-3 mb-0">@loadError</div>
        }
    </div>
</div>

@code {
    [Parameter] public int SelectedCourseId { get; set; }
    [Parameter] public int SelectedModuleId { get; set; }

    [Parameter] public EventCallback<int> SelectedCourseIdChanged { get; set; }
    [Parameter] public EventCallback<int> SelectedModuleIdChanged { get; set; }

    private List<CourseDto> courses = [];
    private List<ModuleDto> allModules = [];
    private List<ModuleDto> modules = [];
    private string? loadError;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        ApplyModuleFilter();

        if (SelectedCourseId == 0 && SelectedModuleId != 0)
        {
            SelectedModuleId = 0;
            await SelectedModuleIdChanged.InvokeAsync(0);
        }
    }

    private async Task LoadDataAsync()
    {
        loadError = null;

        try
        {
            var coursesResult = await CourseService.GetAllCoursesAsync(1, 200);
            courses = coursesResult?.Items?.ToList() ?? [];

            var modulesResult = await ModuleService.GetAllModulesAsync(1, 500);
            allModules = modulesResult?.Items?.ToList() ?? [];

            ApplyModuleFilter();
        }
        catch (Exception ex)
        {
            loadError = $"Failed to load filters. {ex.Message}";
        }
    }

    private void ApplyModuleFilter()
    {
        modules = SelectedCourseId > 0
            ? allModules.Where(m => m.CourseId == SelectedCourseId).ToList()
            : [];

        if (SelectedModuleId > 0 && !modules.Any(m => m.Id == SelectedModuleId))
        {
            SelectedModuleId = 0;
        }
    }

    private async Task HandleCourseChanged(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var courseId))
            courseId = 0;

        SelectedCourseId = courseId;
        SelectedModuleId = 0;

        ApplyModuleFilter();

        await SelectedCourseIdChanged.InvokeAsync(SelectedCourseId);
        await SelectedModuleIdChanged.InvokeAsync(SelectedModuleId);
    }

    private async Task HandleModuleChanged(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var moduleId))
            moduleId = 0;

        SelectedModuleId = moduleId;
        await SelectedModuleIdChanged.InvokeAsync(SelectedModuleId);
    }

    private async Task ClearFilters()
    {
        SelectedCourseId = 0;
        SelectedModuleId = 0;
        ApplyModuleFilter();

        await SelectedCourseIdChanged.InvokeAsync(0);
        await SelectedModuleIdChanged.InvokeAsync(0);
    }
}