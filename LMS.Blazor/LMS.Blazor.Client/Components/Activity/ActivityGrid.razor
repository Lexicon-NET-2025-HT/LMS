@using LMS.Shared.DTOs.Activity
@using LMS.Shared.DTOs.ActivityType
@using BlazorBlueprint.Components
@using LMS.Shared.DTOs.Course
@using LMS.Shared.DTOs.Module
@inject IActivityService ActivityService
@inject IActivityTypeService ActivityTypeService
@inject ICourseService CourseService
@inject IModuleService ModuleService

@if (isLoading)
{
    <BbCard>
        <BbCardContent Class="p-4">
            <div class="d-flex flex-column gap-3">
                <BbSkeleton Class="h-4 w-25" />
                <BbSkeleton Class="h-10 w-full" />
                <BbSkeleton Class="h-10 w-full" />
                <BbSkeleton Class="h-10 w-full" />
            </div>
        </BbCardContent>
    </BbCard>
}
else if (!string.IsNullOrEmpty(loadError))
{
    <BbAlert Variant="AlertVariant.Danger">@loadError</BbAlert>
}
else
{
    @if (ShowCreate)
    {
        <div class="d-flex justify-content-end mb-3">
            <BbButton OnClick="OpenCreateDialog">
                <i class="bi bi-plus-lg me-1"></i>Add Activity
            </BbButton>
        </div>
    }

    @if (!activities.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-lightning fs-1"></i>
            <p class="mt-2 mb-3">No activities found.</p>
            @if (ShowCreate)
            {
                <BbButton OnClick="OpenCreateDialog">Add First Activity</BbButton>
            }
        </div>
    }
    else
    {
        <BbCard>
            <BbCardContent Class="p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Type</th>
                                <th>Start Time</th>
                                <th>End Time</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var activity in activities)
                            {
                                var typeName = activityTypes
                                    .FirstOrDefault(t => t.Id == activity.ActivityTypeId)?.Name ?? "-";

                                <tr>
                                    <td>
                                        <div class="fw-semibold">@activity.Name</div>
                                        @if (!string.IsNullOrWhiteSpace(activity.Description))
                                        {
                                            <div class="text-muted small text-truncate" style="max-width: 320px;">
                                                @activity.Description
                                            </div>
                                        }
                                    </td>
                                    <td>@typeName</td>
                                    <td>@(activity.StartTime?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                                    <td>@(activity.EndTime.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                                    <td class="text-end">
                                        @if (ShowEdit)
                                        {
                                            <div class="d-inline-flex gap-2">
                                                <BbButton Size="ButtonSize.Small"
                                                          Variant="ButtonVariant.Outline"
                                                          OnClick="() => OpenEditDialog(activity)">
                                                    <i class="bi bi-pencil"></i>
                                                </BbButton>

                                                <BbButton Size="ButtonSize.Small"
                                                          Variant="ButtonVariant.Destructive"
                                                          OnClick="() => HandleDelete(activity.Id)">
                                                    <i class="bi bi-trash"></i>
                                                </BbButton>
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </BbCardContent>
        </BbCard>

        @if (totalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center flex-wrap">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <button class="page-link"
                                @onclick="() => GoToPageAsync(currentPage - 1)">
                            Previous
                        </button>
                    </li>

                    @for (int i = 1; i <= totalPages; i++)
                    {
                        var pageNum = i;
                        <li class="page-item @(currentPage == pageNum ? "active" : "")">
                            <button class="page-link"
                                    @onclick="() => GoToPageAsync(pageNum)">
                                @pageNum
                            </button>
                        </li>
                    }

                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <button class="page-link"
                                @onclick="() => GoToPageAsync(currentPage + 1)">
                            Next
                        </button>
                    </li>
                </ul>
            </nav>
        }
    }
}

<ActivityDialog @bind-Open="dialogOpen"
                IsEditing="isEditing"
                Model="formModel"
                ActivityTypes="activityTypes"
                Courses="activeCourses"
                Modules="availableModules"
                OnCourseChanged="HandleCourseChanged"
                OnSave="HandleSave"
                OnAddActivityType="OpenActivityTypeDialog"
                OnDeleteActivityType="HandleDeleteActivityType"
                ActivityTypeError="@activityTypeError" />

<BbDialog @bind-Open="activityTypeDialogOpen">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>Add Activity Type</BbDialogTitle>
            <BbDialogDescription>
                Create a new activity type and select it for this activity.
            </BbDialogDescription>
        </BbDialogHeader>

        <div class="d-flex flex-column gap-3 py-3">
            @if (!string.IsNullOrWhiteSpace(activityTypeError))
            {
                <BbAlert Variant="AlertVariant.Danger" Class="mb-0">
                    @activityTypeError
                </BbAlert>
            }

            <div>
                <label class="form-label fw-medium" style="font-size:0.85rem;">Type Name</label>
                <BbInput Class="mb-2" @bind-Value="newActivityTypeName" Placeholder="e.g. Quiz, Workshop, Exam" />
                <BbTextarea @bind-Value="newActivityTypeDescription" Placeholder="e.g. Description..." />
            </div>
        </div>

        <BbDialogFooter>
            <BbButton Variant="ButtonVariant.Outline"
                      OnClick="@(() => activityTypeDialogOpen = false)">
                Cancel
            </BbButton>

            <BbButton OnClick="HandleCreateActivityType"
                      Disabled="isCreatingActivityType">
                @(isCreatingActivityType ? "Saving..." : "Save")
            </BbButton>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>