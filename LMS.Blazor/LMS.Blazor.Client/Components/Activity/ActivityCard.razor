@using Domain.Models.Entities
@using LMS.Shared.DTOs.Activity
@using BlazorBlueprint.Components

<BbCard class="overflow-hidden transition-all duration-200 hover:shadow-md hover:scale-[1.01]">

    <div class="px-3 py-2 text-xs font-bold text-white"
         style="background: @GetGradient(Activity.ActivityTypeName);">

        @Activity.ActivityTypeName
    </div>

    <BbCardHeader class="py-2">
        <BbCardTitle class="text-sm">
            @Activity.Name
        </BbCardTitle>
    </BbCardHeader>

    <BbCardContent class="text-sm opacity-80">
        <BbCardDescription class="line-clamp-2 hover:line-clamp-none">
            @Activity.Description
        </BbCardDescription>
    </BbCardContent>

    <div class="border-t border-black/10 mx-3"></div>

    <BbCardFooter class="flex items-center justify-end gap-3 text-xs opacity-70 py-2">

        <div class="flex items-center gap-1">
            <span>@Activity.StartTime?.ToString("MMM dd HH:mm") ?? ""</span>
        </div>

        <span class="opacity-50">→</span>

        <div class="flex items-center gap-1">
            <span>@Activity.EndTime.ToString("MMM dd HH:mm")</span>
        </div>

    </BbCardFooter>

</BbCard>

@code {
    [Parameter] public ActivityDto Activity { get; set; } = default!;

    private string GetGradient(string activityTypeName) => activityTypeName switch
    {
        "Lecture" =>
            "linear-gradient(135deg,#2563eb,#60a5fa)",

        "Exercise" =>
            "linear-gradient(135deg,#16a34a,#4ade80)",

        "Assignment" =>
            "linear-gradient(135deg,#f97316,#fb923c)",

        "ELearning" =>
            "linear-gradient(135deg,#7c3aed,#a78bfa)",

        _ =>
            "linear-gradient(135deg,#6b7280,#9ca3af)"
    };
}