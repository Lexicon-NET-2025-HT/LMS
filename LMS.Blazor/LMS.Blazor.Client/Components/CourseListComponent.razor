@using LMS.Shared.DTOs.Course

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Start Date</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var course in Courses)
            {
                <tr>
                    <td>@course.Name</td>
                    <td class="text-truncate" style="max-width: 300px;">@course.Description</td>
                    <td>@course.StartDate.ToString("yyyy-MM-dd")</td>
                    <td class="text-center">
                        <button class="btn btn-sm btn-outline-primary me-1"
                                @onclick="() => OnEdit.InvokeAsync(course)">
                            <i class="bi bi-pencil me-1"></i>Edit
                        </button>
                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="() => OnDelete.InvokeAsync(course)">
                            <i class="bi bi-trash me-1"></i>Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired]
    public List<CourseDto> Courses { get; set; } = [];

    [Parameter, EditorRequired]
    public EventCallback<CourseDto> OnEdit { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<CourseDto> OnDelete { get; set; }
}