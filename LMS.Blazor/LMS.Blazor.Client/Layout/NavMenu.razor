@implements IDisposable
@inject NavigationManager NavigationManager
@using Microsoft.AspNetCore.Components.Authorization

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">
            <span class="brand-title">Lexicon LMS</span>
            <span class="brand-subtitle">Learning Platform</span>
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler')?.click()">
    <nav class="flex-column">

        <AuthorizeView>
            <NotAuthorized>
                <div class="nav-section">
                    <div class="nav-section-title">Account</div>

                    <div class="nav-item">
                        <NavLink class="nav-link" href="/Account/Login">
                            <span class="bi bi-box-arrow-in-right-nav-menu" aria-hidden="true"></span>
                            Login
                        </NavLink>
                    </div>

                    <div class="nav-item">
                        <NavLink class="nav-link" href="/Account/Register">
                            <span class="bi bi-person-plus-nav-menu" aria-hidden="true"></span>
                            Register
                        </NavLink>
                    </div>
                </div>
            </NotAuthorized>
        </AuthorizeView>

        <AuthorizeView Roles="Teacher">
            <Authorized>
                <div class="nav-section">
                    <div class="nav-section-title">teacher</div>

                    <div class="nav-item">
                        <NavLink class="nav-link" href="/admin">
                            <span class="bi bi-grid-nav-menu" aria-hidden="true"></span>
                            Dashboard
                        </NavLink>
                    </div>
                    
                    <div class="nav-item">
                        <NavLink class="nav-link" href="/admin/courses">
                            <span class="bi bi-book-nav-menu" aria-hidden="true"></span>
                            Courses
                        </NavLink>
                    </div>

                    <div class="nav-item">
                        <NavLink class="nav-link" href="/admin/modules">
                            <span class="bi bi-folder-nav-menu" aria-hidden="true"></span>
                            Modules
                        </NavLink>
                    </div>

                    <div class="nav-item">
                        <NavLink class="nav-link" href="/admin/activities">
                            <span class="bi bi-calendar-nav-menu" aria-hidden="true"></span>
                            Activities
                        </NavLink>
                    </div>

                    <div class="nav-item">
                        <NavLink class="nav-link" href="/admin/documents">
                            <span class="bi bi-file-earmark-nav-menu" aria-hidden="true"></span>
                            Documents
                        </NavLink>
                    </div>
                    
                    <div class="nav-item">
                        <NavLink class="nav-link" href="/admin/students">
                            <span class="bi bi-people-nav-menu" aria-hidden="true"></span>
                            Students
                        </NavLink>
                    </div>
                </div>

                <div class="nav-section">
                    <div class="nav-section-title">Account</div>

                    <div class="nav-item">
                        <NavLink class="nav-link" href="Account/Manage">
                            <span class="bi bi-person-nav-menu" aria-hidden="true"></span>
                            Profile
                        </NavLink>
                    </div>

                    <div class="nav-item">
                        <form action="Account/Logout" method="post">
                            <AntiforgeryToken />
                            <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                            <button type="submit" class="nav-link">
                                <span class="bi bi-arrow-bar-left-nav-menu" aria-hidden="true"></span> Logout
                            </button>
                        </form>
                    </div>
                </div>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Roles="Student">
            <Authorized>
                <div class="nav-section">
                    <div class="nav-section-title">Student</div>

                    <div class="nav-item">
                        <NavLink class="nav-link" href="/student/dashboard">
                            <span class="bi bi-grid-nav-menu" aria-hidden="true"></span>
                            Dashboard
                        </NavLink>
                    </div>

                    <div class="nav-item">
                        <NavLink class="nav-link" href="/student/courses">
                            <span class="bi bi-book-nav-menu" aria-hidden="true"></span>
                            My Courses
                        </NavLink>
                    </div>

                    <div class="nav-item">
                        <NavLink class="nav-link" href="/student/modules">
                            <span class="bi bi-folder-nav-menu" aria-hidden="true"></span>
                            My Modules
                        </NavLink>
                    </div>

                    <div class="nav-item">
                        <NavLink class="nav-link" href="/student/activities">
                            <span class="bi bi-calendar-nav-menu" aria-hidden="true"></span>
                            My Activities
                        </NavLink>
                    </div>

                    <div class="nav-item">
                        <NavLink class="nav-link" href="/student/documents">
                            <span class="bi bi-file-earmark-nav-menu" aria-hidden="true"></span>
                            Documents
                        </NavLink>
                    </div>
                </div>

                <div class="nav-section">
                    <div class="nav-section-title">Account</div>

                    <div class="nav-item">
                        <div class="nav-item">
                            <NavLink class="nav-link" href="Account/Manage">
                                <span class="bi bi-person-nav-menu" aria-hidden="true"></span>
                                Profile
                            </NavLink>
                        </div>

                        <form action="Account/Logout" method="post">
                            <AntiforgeryToken />
                            <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                            <button type="submit" class="nav-link">
                                <span class="bi bi-arrow-bar-left-nav-menu" aria-hidden="true"></span> Logout
                            </button>
                        </form>
                    </div>
                </div>
            </Authorized>
        </AuthorizeView>

    </nav>
</div>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
