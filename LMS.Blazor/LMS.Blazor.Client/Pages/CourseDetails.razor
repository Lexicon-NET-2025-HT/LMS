@page "/admin/courses/{CourseId:int}/details"
@attribute [Authorize(Roles = "Teacher")]
@using LMS.Shared.DTOs.Course
@using LMS.Shared.DTOs.Module
@using LMS.Shared.DTOs.User
@inject ICourseService CourseService
@inject NavigationManager Navigation

<PageTitle>Course Details</PageTitle>

<div class="container-fluid py-4">

    @* ---- Header ---- *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
        <h2 class="mb-0">Course Details</h2>
        <button class="btn btn-outline-secondary" title="Back to Courses" @onclick="GoBack">
            <i class="bi bi-arrow-left"></i>
            <span class="d-none d-md-inline ms-1">Back to Courses</span>
        </button>
    </div>

    @* ---- Feedback ---- *@
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible">
            @successMessage
            <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Loading course details...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">
            <p>@errorMessage</p>
            <button class="btn btn-outline-danger btn-sm" @onclick="LoadCourseAsync">Retry</button>
        </div>
    }
    else if (course is null)
    {
        <div class="alert alert-warning">Course not found.</div>
    }
    else
    {
        @* ---- Course Info ---- *@
        <div class="card mb-4">
            <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
                <h5 class="mb-0">@course.Name</h5>
                <div class="d-flex gap-2 flex-wrap">
                    <span class="badge bg-primary">@modules.Count Modules</span>
                    <span class="badge bg-success">@students.Count Students</span>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <p class="text-muted mb-1 small">Description</p>
                        <p>@course.Description</p>
                    </div>
                    <div class="col-md-3">
                        <p class="text-muted mb-1 small">Start Date</p>
                        <p>@course.StartDate.ToString("yyyy-MM-dd")</p>
                    </div>
                    <div class="col-md-3">
                        <p class="text-muted mb-1 small">Teachers</p>
                        <p>@(course.TeacherIds.Any() ? string.Join(", ", course.TeacherIds) : "None assigned")</p>
                    </div>
                </div>
            </div>
        </div>

        @* ==============================
           MODULES SECTION
           ============================== *@
        <div class="card mb-4">
            <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
                <h6 class="mb-0"><i class="bi bi-journal-text me-2"></i>Modules</h6>
                <button class="btn btn-sm btn-primary" title="Add Module" @onclick="() => showAddModule = !showAddModule">
                    <i class="bi bi-plus-lg"></i>
                    <span class="d-none d-md-inline ms-1">Add Module</span>
                </button>
            </div>

            @* ---- Add Module Panel ---- *@
            @if (showAddModule)
            {
                <div class="card-body border-bottom bg-light">
                    <div class="row g-2 align-items-end">
                        <div class="col-md-3">
                            <label class="form-label small fw-semibold">Name *</label>
                            <input class="form-control form-control-sm" @bind="newModule.Name" placeholder="Module name" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-semibold">Description</label>
                            <input class="form-control form-control-sm" @bind="newModule.Description" placeholder="Description" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small fw-semibold">Start Date *</label>
                            <input type="date" class="form-control form-control-sm" @bind="newModule.StartDate" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small fw-semibold">End Date</label>
                            <input type="date" class="form-control form-control-sm" @bind="newModule.EndDate" />
                        </div>
                        <div class="col-12 col-md-2 d-flex gap-1">
                            <button class="btn btn-sm btn-success w-100" @onclick="AddModuleAsync">Save</button>
                            <button class="btn btn-sm btn-secondary" @onclick="() => showAddModule = false">✕</button>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(moduleError))
                    {
                        <p class="text-danger small mt-1 mb-0">@moduleError</p>
                    }
                </div>
            }

            <div class="card-body p-0">
                @if (!modules.Any())
                {
                    <p class="text-muted p-3 mb-0">No modules yet. Add the first one.</p>
                }
                else
                {
                    @foreach (var module in modules)
                    {
                        <div class="border-bottom">
                            @* Module row *@
                            <div class="d-flex justify-content-between align-items-center gap-2 px-3 py-2">
                                <div class="flex-grow-1 overflow-hidden">
                                    <div class="fw-semibold text-truncate">@module.Name</div>
                                    <div class="text-muted small mt-1">@module.StartDate.ToString("yyyy-MM-dd") → @module.EndDate?.ToString("yyyy-MM-dd")</div>
                                    <div class="mt-1">
                                        <div class="d-flex justify-content-between align-items-center gap-2">
                                            <span class="badge bg-secondary" style="font-size:0.7rem;">@module.ActivityCount activities</span>
                                            <div class="d-flex gap-1 flex-shrink-0">
                                                <button class="btn btn-sm btn-outline-primary"
                                                        title="Toggle Activities"
                                                        @onclick="() => ToggleActivities(module.Id)">
                                                    <i class="bi bi-list-ul"></i>
                                                    <span class="d-none d-md-inline ms-1">Activities</span>
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger"
                                                        title="Remove Module"
                                                        @onclick="() => RemoveModule(module.Id)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                              @*   <div class="d-flex gap-1 flex-shrink-0">
                                    <button class="btn btn-sm btn-outline-primary"
                                            title="Toggle Activities"
                                            @onclick="() => ToggleActivities(module.Id)">
                                        <i class="bi bi-list-ul"></i>
                                        <span class="d-none d-md-inline ms-1">Activities</span>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger"
                                            title="Remove Module"
                                            @onclick="() => RemoveModule(module.Id)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div> *@
                            </div>

                            @* Activities sub-panel *@
                            @if (expandedModuleId == module.Id)
                            {
                                <div class="bg-light px-4 py-3">

                                    @* Add Activity inline *@
                                    <div class="row g-2 align-items-end mb-3">
                                        <div class="col-12 col-sm-6 col-xl-3">
                                            <label class="form-label small fw-semibold mb-1">Activity Name</label>
                                            <input class="form-control form-control-sm"
                                                   @bind="newActivityName" placeholder="e.g. Lecture 1" />
                                        </div>
                                        <div class="col-12 col-sm-6 col-xl-2">
                                            <label class="form-label small fw-semibold mb-1">Type</label>
                                            <select class="form-select form-select-sm" @bind="newActivityType">
                                                <option value="Lecture">Lecture</option>
                                                <option value="Exercise">Exercise</option>
                                                <option value="ELearning">E-Learning</option>
                                            </select>
                                        </div>
                                        <div class="col-12 col-sm-6 col-xl-3">
                                            <label class="form-label small fw-semibold mb-1">Start</label>
                                            <input type="datetime-local" class="form-control form-control-sm"
                                                   @bind="newActivityStart" />
                                        </div>
                                        <div class="col-12 col-sm-6 col-xl-3">
                                            <label class="form-label small fw-semibold mb-1">End</label>
                                            <input type="datetime-local" class="form-control form-control-sm"
                                                   @bind="newActivityEnd" />
                                        </div>
                                        <div class="col-12 col-xl-1 d-flex gap-1">
                                            <button class="btn btn-sm btn-primary flex-fill"
                                                    title="Add Activity"
                                                    @onclick="() => AddActivity(module.Id, ActivityKind.Activity)">
                                                <i class="bi bi-plus-lg"></i>
                                                <span class="d-none d-xl-inline ms-1">Activity</span>
                                            </button>
                                            <button class="btn btn-sm btn-outline-primary flex-fill"
                                                    title="Add Assignment"
                                                    @onclick="() => AddActivity(module.Id, ActivityKind.Assignment)">
                                                <i class="bi bi-plus-lg"></i>
                                                <span class="d-none d-xl-inline ms-1">Assignment</span>
                                            </button>
                                        </div>
                                    </div>

                                    @* Activity list *@
                                    @{
                                        var acts = activities.Where(a => a.ModuleId == module.Id).ToList();
                                    }
                                    @if (!acts.Any())
                                    {
                                        <p class="text-muted small mb-0">No activities yet.</p>
                                    }
                                    else
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-sm table-bordered mb-0 bg-white">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Name</th>
                                                        <th>Type</th>
                                                        <th>Start</th>
                                                        <th>End</th>
                                                        <th></th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var act in acts)
                                                    {
                                                        <tr>
                                                            <td>@act.Name</td>
                                                            <td><span class="badge bg-info text-dark">@act.Type</span></td>
                                                            <td>@act.Start?.ToString("yyyy-MM-dd HH:mm")</td>
                                                            <td>@act.End.ToString("yyyy-MM-dd HH:mm")</td>
                                                            <td>
                                                                <button class="btn btn-sm btn-outline-danger"
                                                                        @onclick="() => RemoveActivity(act.TempId)">
                                                                    <i class="bi bi-trash"></i>
                                                                </button>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>

                                        @* Sync reminder *@
                                        <div class="alert alert-warning py-1 px-2 mt-2 mb-0 small">
                                            <i class="bi bi-exclamation-triangle me-1"></i>
                                            These activities are stored locally. Save to API when backend is ready.
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </div>

        @* ==============================
           STUDENTS SECTION
           ============================== *@
        <div class="card mb-4">
            <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
                <h6 class="mb-0"><i class="bi bi-people me-2"></i>Students</h6>
                <button class="btn btn-sm btn-primary" title="Enroll Student" @onclick="() => showEnrollStudent = !showEnrollStudent">
                    <i class="bi bi-person-plus"></i>
                    <span class="d-none d-md-inline ms-1">Enroll Student</span>
                </button>
            </div>

            @* ---- Enroll Panel ---- *@
            @if (showEnrollStudent)
            {
                <div class="card-body border-bottom bg-light">
                    <div class="row g-2 align-items-end">
                        <div class="col-12 col-md-6">
                            <label class="form-label small fw-semibold">Select Student</label>
                            <select class="form-select form-select-sm" @bind="selectedStudentId">
                                <option value="">-- pick a student --</option>
                                @foreach (var s in availableStudents.Where(s => !students.Any(e => e.Id == s.Id)))
                                {
                                    <option value="@s.Id">@s.UserName (@s.Email)</option>
                                }
                            </select>
                        </div>
                        <div class="col-12 col-md-auto d-flex gap-1">
                            <button class="btn btn-sm btn-success" @onclick="EnrollStudent">Enroll</button>
                            <button class="btn btn-sm btn-secondary" @onclick="() => showEnrollStudent = false">✕</button>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(studentError))
                    {
                        <p class="text-danger small mt-1 mb-0">@studentError</p>
                    }
                </div>
            }

            <div class="card-body p-0">
                @if (!students.Any())
                {
                    <p class="text-muted p-3 mb-0">No students enrolled yet.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Username</th>
                                    <th class="d-none d-sm-table-cell">Email</th>
                                    <th style="width:48px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var student in students)
                                {
                                    <tr>
                                        <td class="text-truncate" style="max-width:150px;">@student.UserName</td>
                                        <td class="d-none d-sm-table-cell text-truncate" style="max-width:200px;">@student.Email</td>
                                        <td class="text-end text-nowrap">
                                            <button class="btn btn-sm btn-outline-danger"
                                                    title="Remove Student"
                                                    @onclick="() => RemoveStudent(student.Id)">
                                                <i class="bi bi-person-dash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        @* ==============================
           DOCUMENTS SECTION
           ============================== *@
        <div class="card mb-4">
            <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
                <h6 class="mb-0"><i class="bi bi-file-earmark me-2"></i>Documents</h6>
                <button class="btn btn-sm btn-primary" title="Upload Document" @onclick="() => showUploadDocument = !showUploadDocument">
                    <i class="bi bi-upload"></i>
                    <span class="d-none d-md-inline ms-1">Upload Document</span>
                </button>
            </div>

            @* ---- Upload Panel ---- *@
            @if (showUploadDocument)
            {
                <div class="card-body border-bottom bg-light">
                    <div class="row g-2 align-items-end">
                        <div class="col-12 col-md-5">
                            <label class="form-label small fw-semibold">Display Name *</label>
                            <input class="form-control form-control-sm" @bind="newDocName" placeholder="e.g. Lecture Slides Week 1" />
                        </div>
                        <div class="col-12 col-md-5">
                            <label class="form-label small fw-semibold">File (mock)</label>
                            <input type="file" class="form-control form-control-sm" @onchange="HandleFilePicked" />
                        </div>
                        <div class="col-12 col-md-auto d-flex gap-1">
                            <button class="btn btn-sm btn-success" @onclick="AddDocument">Add</button>
                            <button class="btn btn-sm btn-secondary" @onclick="() => showUploadDocument = false">✕</button>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(documentError))
                    {
                        <p class="text-danger small mt-1 mb-0">@documentError</p>
                    }
                </div>
            }

            <div class="card-body p-0">
                @if (!documents.Any())
                {
                    <p class="text-muted p-3 mb-0">No documents uploaded yet.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Name</th>
                                    <th class="d-none d-sm-table-cell">File</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var doc in documents)
                                {
                                    <tr>
                                        <td>@doc.DisplayName</td>
                                        <td class="d-none d-sm-table-cell"><span class="text-muted small">@doc.FileName</span></td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-outline-danger"
                                                    title="Remove Document"
                                                    @onclick="() => RemoveDocument(doc.TempId)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="alert alert-warning py-1 px-2 m-2 small">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        Documents are stored locally. Upload to API when backend is ready.
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int CourseId { get; set; }

    // ---- API state ----
    private CourseDto? course;
    private bool isLoading;
    private string? errorMessage;
    private string? successMessage;

    // ---- Module state ----
    private List<ModuleDto> modules = [];
    private List<StudentBasicDto> students = [];
    private bool showAddModule;
    private string? moduleError;
    private int? expandedModuleId;
    private NewModuleModel newModule = new();

    // ---- Activity state ----
    private List<LocalActivity> activities = [];
    private string newActivityName = string.Empty;
    private string newActivityType = "Lecture";
    private DateTime? newActivityStart;
    private DateTime newActivityEnd = DateTime.Today.AddHours(17);
    private int activityCounter = 0;

    // ---- Student state ----
    private List<StudentBasicDto> availableStudents = [];
    private bool showEnrollStudent;
    private string selectedStudentId = string.Empty;
    private string? studentError;

    // ---- Document state ----
    private List<LocalDocument> documents = [];
    private bool showUploadDocument;
    private string newDocName = string.Empty;
    private string pickedFileName = string.Empty;
    private string? documentError;
    private int documentCounter = 0;

    // ---- Lifecycle ----
    protected override async Task OnInitializedAsync()
        => await LoadCourseAsync();

    private async Task LoadCourseAsync()
    {
        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            course = await CourseService.GetCourseByIdAsync(CourseId);
            var detail = await CourseService.GetCourseDetailByIdAsync(CourseId);

            if (detail is not null)
            {
                modules = detail.Modules;
                students = detail.Students;
            }

            // Mock available students for enroll dropdown
            // TODO: replace with real GET /api/users?role=Student when ready
            availableStudents =
            [
                new() { Id = "mock-1", UserName = "alice@test.com", Email = "alice@test.com" },
                new() { Id = "mock-2", UserName = "bob@test.com", Email = "bob@test.com" },
                new() { Id = "mock-3", UserName = "charlie@test.com", Email = "charlie@test.com" },
                new() { Id = "mock-4", UserName = "diana@test.com", Email = "diana@test.com" },
            ];
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load course. {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    // ---- Module actions ----
    private async Task AddModuleAsync()
    {
        moduleError = null;

        if (string.IsNullOrWhiteSpace(newModule.Name))
        {
            moduleError = "Name is required.";
            return;
        }

        // TODO: replace with real POST /api/modules when ready
        modules.Add(new ModuleDto
        {
            Id = modules.Count + 1,
            CourseId = CourseId,
            CourseName = course?.Name ?? string.Empty,
            Name = newModule.Name,
            Description = newModule.Description,
            StartDate = newModule.StartDate,
            EndDate = newModule.EndDate,
            ActivityCount = 0
        });

        successMessage = $"Module '{newModule.Name}' added (locally).";
        newModule = new();
        showAddModule = false;
        await Task.CompletedTask;
    }

    private void RemoveModule(int moduleId)
    {
        modules.RemoveAll(m => m.Id == moduleId);
        activities.RemoveAll(a => a.ModuleId == moduleId);
        if (expandedModuleId == moduleId) expandedModuleId = null;
    }

    private void ToggleActivities(int moduleId)
        => expandedModuleId = expandedModuleId == moduleId ? null : moduleId;

    // ---- Activity actions ----
    private void AddActivity(int moduleId, ActivityKind kind)
    {
        if (string.IsNullOrWhiteSpace(newActivityName)) return;

        var type = kind == ActivityKind.Assignment ? "Assignment" : newActivityType;

        activities.Add(new LocalActivity
        {
            TempId = ++activityCounter,
            ModuleId = moduleId,
            Name = newActivityName,
            Type = type,
            Start = newActivityStart,
            End = newActivityEnd
        });

        // Update count on module
        var mod = modules.FirstOrDefault(m => m.Id == moduleId);
        if (mod is not null)
            modules[modules.IndexOf(mod)] = mod with { ActivityCount = mod.ActivityCount + 1 };

        successMessage = $"'{newActivityName}' added locally.";
        newActivityName = string.Empty;
    }

    private void RemoveActivity(int tempId)
    {
        var act = activities.FirstOrDefault(a => a.TempId == tempId);
        if (act is null) return;

        var mod = modules.FirstOrDefault(m => m.Id == act.ModuleId);
        if (mod is not null)
            modules[modules.IndexOf(mod)] = mod with { ActivityCount = Math.Max(0, mod.ActivityCount - 1) };

        activities.Remove(act);
    }

    // ---- Student actions ----
    private void EnrollStudent()
    {
        studentError = null;

        if (string.IsNullOrEmpty(selectedStudentId))
        {
            studentError = "Please select a student.";
            return;
        }

        var student = availableStudents.FirstOrDefault(s => s.Id == selectedStudentId);
        if (student is null) return;

        // TODO: replace with real PUT /api/courses/{id}/enroll when ready
        students.Add(student with { CourseId = CourseId, CourseName = course?.Name });
        successMessage = $"{student.UserName} enrolled (locally).";
        selectedStudentId = string.Empty;
        showEnrollStudent = false;
    }

    private void RemoveStudent(string studentId)
        => students.RemoveAll(s => s.Id == studentId);

    // ---- Document actions ----
    private void HandleFilePicked(ChangeEventArgs e)
        => pickedFileName = e.Value?.ToString() ?? string.Empty;

    private void AddDocument()
    {
        documentError = null;

        if (string.IsNullOrWhiteSpace(newDocName))
        {
            documentError = "Display name is required.";
            return;
        }

        // TODO: replace with real POST /api/documents when ready
        documents.Add(new LocalDocument
        {
            TempId = ++documentCounter,
            DisplayName = newDocName,
            FileName = string.IsNullOrEmpty(pickedFileName) ? "no-file-selected" : pickedFileName
        });

        successMessage = $"Document '{newDocName}' added (locally).";
        newDocName = string.Empty;
        pickedFileName = string.Empty;
        showUploadDocument = false;
    }

    private void RemoveDocument(int tempId)
        => documents.RemoveAll(d => d.TempId == tempId);

    private void GoBack() => Navigation.NavigateTo("/admin/courses");

    // ---- Local models ----
    private class NewModuleModel
    {
        public string Name { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public DateTime StartDate { get; set; } = DateTime.Today;
        public DateTime? EndDate { get; set; } = DateTime.Today.AddDays(14);
    }

    private class LocalActivity
    {
        public int TempId { get; set; }
        public int ModuleId { get; set; }
        public string Name { get; set; } = string.Empty;
        public string Type { get; set; } = string.Empty;
        public DateTime? Start { get; set; }
        public DateTime End { get; set; }
    }

    private class LocalDocument
    {
        public int TempId { get; set; }
        public string DisplayName { get; set; } = string.Empty;
        public string FileName { get; set; } = string.Empty;
    }

    private enum ActivityKind { Activity, Assignment }
}
