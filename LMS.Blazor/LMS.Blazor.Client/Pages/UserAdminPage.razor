@page "/admin/users"
@attribute [Authorize(Roles = "Teacher")]
@using LMS.Blazor.Client.Components
@using LMS.Shared.DTOs.Common
@using LMS.Shared.DTOs.User
@inject IApiService ApiService
@inject NavigationManager Navigation

<PageTitle>User Management</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">User Management</h2>
        @if (!showForm)
        {
            <button class="btn btn-primary" @onclick="HandleCreateClicked">
                <i class="bi bi-plus-lg me-1"></i> Create User
            </button>
        }
    </div>

    @* ---- Feedback messages ---- *@
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @successMessage
            <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
        </div>
    }

    @* ---- Form section ---- *@
    @if (showForm)
    {
        <UserFormComponent
            User="selectedUser"
            OnSubmit="HandleFormSubmit"
            OnCancel="HandleFormCancel" />
    }

    @* ---- List section ---- *@
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2 text-muted">Loading users...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(loadError))
    {
        <div class="alert alert-danger">
            <p>@loadError</p>
            <button class="btn btn-outline-danger btn-sm" @onclick="LoadUsersAsync">Retry</button>
        </div>
    }
    else if (!users.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-journal-x fs-1"></i>
            <p class="mt-2">No users found. Create your first user.</p>
        </div>
    }
    else
{
    <UserListComponent
        Users="users"
        OnEdit="HandleEditClicked"
        OnDelete="HandleDeleteClicked" />

    @* ---- Pagination ---- *@
    @if (totalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => GoToPageAsync(currentPage - 1)">Previous</button>
                </li>
                @for (int i = 1; i <= totalPages; i++)
                {
                    var pageNum = i;
                        <li class="page-item @(currentPage == pageNum ? "active" : "")">
                            <button class="page-link" @onclick="() => GoToPageAsync(pageNum)">@pageNum</button>
                    </li>
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <button class="page-link" @onclick="() => GoToPageAsync(currentPage + 1)">Next</button>
                </li>
            </ul>
        </nav>
    }
}
</div>

@* ---- Delete confirmation modal ---- *@
@if (showDeleteConfirm && userToDelete is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                </div>
                <div class="modal-body">
                    Are you sure you want to delete <strong>@userToDelete.Name</strong>?
                    This action cannot be undone.
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button class="btn btn-danger" @onclick="ConfirmDeleteAsync">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<UserDto> users = [];
    private UserDto? selectedUser;
    private bool isLoading;
    private bool showForm;
    private bool showDeleteConfirm;
    private UserDto? userToDelete;
    private string? errorMessage;
    private string? successMessage;
    private string? loadError;

    // Pagination state
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalCount = 0;
    private int totalPages = 0;

    protected override async Task OnInitializedAsync()
        => await LoadUsersAsync();

    private async Task LoadUsersAsync()
    {
        isLoading = true;
        loadError = null;
        StateHasChanged();

        try
        {
            var result = await ApiService.GetAsync<PagedResultDto<UserDto>>($"api/users?page={currentPage}&pageSize={pageSize}");
            if (result is not null)
            {
                users = result.Items;
                totalCount = result.TotalCount;
                totalPages = result.TotalPages;
            }
        }
        catch (Exception ex)
        {
            loadError = $"Failed to load users. {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void HandleCreateClicked()
    {
        selectedUser = null;
        showForm = true;
    }

    private void HandleEditClicked(UserDto user)
    {
        selectedUser = user;
        showForm = true;
    }

    private async Task HandleFormSubmit(UserDto result)
    {
        showForm = false;
        selectedUser = null;
        await LoadUsersAsync();
        successMessage = $"User '{result.Name}' saved successfully.";
    }

    private void HandleFormCancel()
    {
        showForm = false;
        selectedUser = null;
    }

    private void HandleDeleteClicked(UserDto user)
    {
        userToDelete = user;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        userToDelete = null;
        showDeleteConfirm = false;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (userToDelete is null) return;
        await ApiService.DeleteAsync($"api/users/{userToDelete.Id}");
        successMessage = $"User '{userToDelete.Name}' deleted successfully.";
        userToDelete = null;
        showDeleteConfirm = false;
        await LoadUsersAsync();
    }

    private async Task GoToPageAsync(int page)
    {
        currentPage = page;
        await LoadUsersAsync();
    }

}
