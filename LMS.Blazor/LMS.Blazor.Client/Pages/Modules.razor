@page "/modules"
@using LMS.Shared.DTOs.Module
@using BlazorBlueprint.Icons.Lucide.Components
@using BlazorBlueprint.Icons.Lucide.Data

<div class="container-fluid px-4 py-5" style="max-width: 1200px; margin: 0 auto;">

    @* ── Header ── *@
    <BbBreadcrumb Class="mb-4">
        <BbBreadcrumbItem>
            <BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink>
        </BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem>
            <BbBreadcrumbPage>Modules</BbBreadcrumbPage>
        </BbBreadcrumbItem>
    </BbBreadcrumb>

    <div class="d-flex justify-content-between align-items-start mb-5 flex-wrap gap-3">
        <div>
            <h1 class="fw-bold mb-1" style="font-size: 1.8rem;">System Development .NET</h1>
            <p class="text-muted mb-0">@modules.Count modules · @modules.Count(IsActive) active now</p>
        </div>
        <div class="d-flex align-items-center gap-3">
            <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="ToggleRole">
                @(isTeacher ? "Switch to Student" : "Switch to Teacher")
            </BbButton>
            @if (isTeacher)
            {
                <BbButton Size="ButtonSize.Small" OnClick="OpenCreateDialog">
                    + Add Module
                </BbButton>
            }
        </div>
    </div>

    @* ── Module Grid ── *@
    <div class="row g-4">
        @foreach (var module in modules)
        {
            var status = GetStatus(module);
            <div class="col-12 col-md-6 col-lg-4">
                <div style="border-radius: 12px; overflow: hidden; height: 100%;
                    display: flex; flex-direction: column;">
                    <BbCard Class="h-100">

                        @* Gradient cover *@
                        <div style="height: 120px; background: @GetGradient(module.Id);
                            display: flex; align-items: center; justify-content: center;
                            position: relative;">
                            <LucideIcon Name="@GetModuleIcon(module.Name)"
                                        Size="48"
                                        Style="color: rgba(255,255,255,0.85);" />

                            <div style="position: absolute; top: 12px; right: 12px;">
                                <BbBadge Variant="@status.Variant">@status.Label</BbBadge>
                            </div>

                            @if (isTeacher)
                            {
                                <div style="position: absolute; top: 12px; left: 12px;">
                                    <BbButton Variant="ButtonVariant.Ghost"
                                              Size="ButtonSize.Small"
                                              Style="background: rgba(0,0,0,0.25); color:white; border-radius: 6px;"
                                              OnClick="@(() => CycleGradient(module.Id))">
                                        🎨
                                    </BbButton>
                                </div>
                            }
                        </div>

                        <BbCardContent Class="p-4">
                            <h5 class="fw-semibold mb-1" style="font-size: 1rem;">@module.Name</h5>
                            <p class="text-muted mb-0" style="font-size: 0.78rem;">
                                @module.StartDate.ToString("MMM dd") –
                                @(module.EndDate?.ToString("MMM dd") ?? "TBD")
                            </p>

                            <BbSeparator Class="my-3" />

                            <p class="text-muted" style="font-size: 0.85rem;
                                overflow: hidden; display: -webkit-box;
                                -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                                @module.Description
                            </p>

                            @if (status.Label == "Active" && module.EndDate.HasValue)
                            {
                                var pct = GetProgress(module);
                                <div class="mt-3">
                                    <div class="d-flex justify-content-between mb-1"
                                         style="font-size: 0.75rem; color: #888;">
                                        <span>Progress</span><span>@pct%</span>
                                    </div>
                                    <div style="height: 6px; background: #e9ecef;
                                        border-radius: 99px; overflow: hidden;">
                                        <div style="width: @pct%; height: 100%;
                                            background: @GetGradient(module.Id);
                                            border-radius: 99px; transition: width 0.4s;">
                                        </div>
                                    </div>
                                </div>
                            }
                        </BbCardContent>

                        <BbCardFooter Class="px-4 pb-4 pt-0 d-flex justify-content-between align-items-center">
                            <BbButton Variant="ButtonVariant.Outline"
                                      Size="ButtonSize.Small"
                                      OnClick="@(() => ViewActivities(module.Id))">
                                Activities
                                <BbBadge Variant="BadgeVariant.Secondary" Class="ms-1">
                                    @module.ActivityCount
                                </BbBadge>
                            </BbButton>

                            @if (isTeacher)
                            {
                                <div class="d-flex gap-2">
                                    <BbButton Variant="ButtonVariant.Ghost"
                                              Size="ButtonSize.Small"
                                              OnClick="@(() => OpenEditDialog(module))">
                                        ✏️
                                    </BbButton>
                                    <BbButton Variant="ButtonVariant.Ghost"
                                              Size="ButtonSize.Small"
                                              Style="color: var(--bb-destructive);"
                                              OnClick="@(() => DeleteModule(module.Id))">
                                        🗑️
                                    </BbButton>
                                </div>
                            }
                        </BbCardFooter>

                    </BbCard>
                </div>
            </div>
        }
    </div>

    @* ── Create / Edit Dialog ── *@
    <BbDialog @bind-Open="isDialogOpen">
        <BbDialogContent>
            <BbDialogHeader>
                <BbDialogTitle>
                    @(isEditing ? "Edit Module" : "Create New Module")
                </BbDialogTitle>
                <BbDialogDescription>
                    @(isEditing ? "Update the module details below." : "Fill in details for the new module.")
                </BbDialogDescription>
            </BbDialogHeader>

            <div class="d-flex flex-column gap-3 py-3">
                <div>
                    <label class="form-label fw-medium" style="font-size: 0.85rem;">Module Name</label>
                    <BbInput @bind-Value="editingModule.Name"
                             Placeholder="e.g. Core C# Programming" />
                </div>
                <div>
                    <label class="form-label fw-medium" style="font-size: 0.85rem;">Description</label>
                    <BbTextarea @bind-Value="editingModule.Description"
                                Placeholder="Brief overview of what this module covers..."
                                Rows="3" />
                </div>
                <div class="row g-2">
                    <div class="col-6">
                        <label class="form-label fw-medium" style="font-size: 0.85rem;">Start Date</label>
                        <BbInput Value="@editingModule.StartDate.ToString("yyyy-MM-dd")"
                                 ValueChanged="@((string v) => editingModule.StartDate = DateTime.Parse(v))"
                                 Style="width:100%;" />
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-medium" style="font-size: 0.85rem;">End Date</label>
                        <BbInput Value="@(editingModule.EndDate?.ToString("yyyy-MM-dd") ?? "")"
                                 ValueChanged="@((string v) => editingModule.EndDate = string.IsNullOrEmpty(v) ? null : DateTime.Parse(v))"
                                 Style="width:100%;" />
                    </div>
                </div>
            </div>

            <BbDialogFooter>
                <BbButton Variant="ButtonVariant.Outline"
                          OnClick="@(() => isDialogOpen = false)">
                    Cancel
                </BbButton>
                <BbButton OnClick="SaveModule">
                    @(isEditing ? "Save Changes" : "Create Module")
                </BbButton>
            </BbDialogFooter>
        </BbDialogContent>
    </BbDialog>

</div>

@code {
    private bool isTeacher = false;
    private bool isDialogOpen = false;
    private bool isEditing = false;

    private ModuleDto editingModule = new()
    {
        Id = 0,
        CourseId = 1,
        CourseName = "Dev .NET",
        Name = "",
        Description = "",
        StartDate = DateTime.Now
    };

    private List<ModuleDto> modules = new()
    {
        new ModuleDto { Id = 1, CourseId = 1, CourseName = "Dev .NET",
            Name = "Introduction to .NET",
            Description = "Getting started with the .NET ecosystem, tooling, and project structure.",
            StartDate = DateTime.Now.AddDays(-10), EndDate = DateTime.Now.AddDays(-5), ActivityCount = 4 },
        new ModuleDto { Id = 2, CourseId = 1, CourseName = "Dev .NET",
            Name = "C# Fundamentals",
            Description = "Deep dive into OOP principles, collections, LINQ, and async patterns.",
            StartDate = DateTime.Now.AddDays(-4), EndDate = DateTime.Now.AddDays(10), ActivityCount = 8 },
        new ModuleDto { Id = 3, CourseId = 1, CourseName = "Dev .NET",
            Name = "Entity Framework Core",
            Description = "Code-first database design, migrations, and querying with EF Core.",
            StartDate = DateTime.Now.AddDays(12), EndDate = DateTime.Now.AddDays(25), ActivityCount = 6 },
    };

    private Dictionary<int, int> gradientIndex = new();

    private static readonly string[] Gradients =
    [
        "linear-gradient(135deg, #667eea, #764ba2)",
        "linear-gradient(135deg, #f093fb, #f5576c)",
        "linear-gradient(135deg, #4facfe, #00f2fe)",
        "linear-gradient(135deg, #43e97b, #38f9d7)",
        "linear-gradient(135deg, #fa709a, #fee140)",
        "linear-gradient(135deg, #a18cd1, #fbc2eb)",
        "linear-gradient(135deg, #fd7943, #f6c843)",
    ];

    private string GetGradient(int id)
    {
        var idx = gradientIndex.GetValueOrDefault(id, id % Gradients.Length);
        return Gradients[idx];
    }

    private void CycleGradient(int id)
    {
        var current = gradientIndex.GetValueOrDefault(id, id % Gradients.Length);
        gradientIndex[id] = (current + 1) % Gradients.Length;
    }

    private string GetModuleIcon(string name) => name.ToLower() switch
    {
        var n when n.Contains("database") || n.Contains("entity") => "database",
        var n when n.Contains("api") => "plug",
        var n when n.Contains("javascript") => "code-2",
        var n when n.Contains("intro") || n.Contains(".net") => "rocket",
        var n when n.Contains("c#") || n.Contains("fundament") => "layers",
        var n when n.Contains("security") || n.Contains("auth") => "shield",
        var n when n.Contains("test") => "flask-conical",
        _ => "book-open"
    };

    private (string Label, BadgeVariant Variant) GetStatus(ModuleDto m)
    {
        var now = DateTime.Now;
        if (m.EndDate.HasValue && m.EndDate < now) return ("Completed", BadgeVariant.Secondary);
        if (m.StartDate > now) return ("Upcoming", BadgeVariant.Outline);
        return ("Active", BadgeVariant.Default);
    }

    private bool IsActive(ModuleDto m)
        => m.StartDate <= DateTime.Now && (!m.EndDate.HasValue || m.EndDate >= DateTime.Now);

    private int GetProgress(ModuleDto m)
    {
        if (!m.EndDate.HasValue) return 0;
        var total = (m.EndDate.Value - m.StartDate).TotalDays;
        var elapsed = (DateTime.Now - m.StartDate).TotalDays;
        return (int)Math.Clamp(elapsed / total * 100, 0, 100);
    }

    private void ToggleRole() => isTeacher = !isTeacher;

    private void OpenCreateDialog()
    {
        isEditing = false;
        editingModule = new()
        {
            Id = 0,
            CourseId = 1,
            CourseName = "Dev .NET",
            Name = "",
            Description = "",
            StartDate = DateTime.Now
        };
        isDialogOpen = true;
    }

    private void OpenEditDialog(ModuleDto module)
    {
        isEditing = true;
        editingModule = module with { };
        isDialogOpen = true;
    }

    private void SaveModule()
    {
        if (isEditing)
        {
            var i = modules.FindIndex(m => m.Id == editingModule.Id);
            if (i != -1) modules[i] = editingModule;
        }
        else
        {
            editingModule.Id = modules.Max(m => m.Id) + 1;
            modules.Add(editingModule);
        }
        isDialogOpen = false;
    }

    private void DeleteModule(int id) => modules.RemoveAll(m => m.Id == id);

    private void ViewActivities(int moduleId)
    {
        // TODO: NavigationManager.NavigateTo($"/modules/{moduleId}/activities");
    }
}