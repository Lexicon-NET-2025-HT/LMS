@page "/modules"
@page "/modules/{CourseId:int}"
@using LMS.Blazor.Client.Components.Module
@using LMS.Blazor.Client.Components.Course
@using LMS.Shared.DTOs.Module
@using LMS.Shared.DTOs.Course
@using LMS.Blazor.Client.Helpers
@inject LMS.Blazor.Client.Services.ICourseService CourseService
@inject LMS.Blazor.Client.Services.IModuleService ModuleService
@inject LMS.Blazor.Client.Services.IApiService ApiService

<div class="py-5" style="margin: 0 !important; margin-left: -1.5rem !important; max-width: none !important; padding-left: 0 !important;">

    <div class="row g-0" style="margin: 0 !important;">
        <aside class="col-auto mb-5 pe-4" style="min-width: 180px; margin-left: 0 !important;">
            <CourseNav />
        </aside>

        <main class="col-md-10">
            <BbBreadcrumb Class="mb-4">
                <BbBreadcrumbItem><BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink></BbBreadcrumbItem>
                <BbBreadcrumbSeparator />
                <BbBreadcrumbItem><BbBreadcrumbPage>Modules</BbBreadcrumbPage></BbBreadcrumbItem>
            </BbBreadcrumb>

            @if (isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2 text-muted">Loading modules...</p>
                </div>
            }
            else if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">
                    <p>@errorMessage</p>
                </div>
            }
            else
            {
                <div class="d-flex justify-content-between align-items-start mb-5 flex-wrap gap-3">
                    <div>
                        <h1 class="fw-bold mb-1" style="font-size:1.8rem;">@(course?.Name ?? "Course Modules")</h1>
                        <p class="text-muted mb-0">@modules.Count modules · @modules.Count(IsActive) active now</p>
                    </div>
                <div class="d-flex align-items-center gap-3">
                    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="ToggleRole">
                        @(isTeacher ? "Switch to Student" : "Switch to Teacher")
                    </BbButton>
                    @if (isTeacher)
                    {
                        <BbButton Size="ButtonSize.Small" OnClick="OpenCreateDialog">+ Add Module</BbButton>
                    }
                </div>
            </div>

                <ModuleGrid Modules="modules"
                            IsTeacher="isTeacher"
                            GradientIndex="gradientIndex"
                            OnCycleGradient="CycleGradient"
                            OnEdit="OpenEditDialog"
                            OnDelete="DeleteModule"
                            OnViewActivities="ViewActivities" />

                <ModuleDialog @bind-Open="isDialogOpen"
                              IsEditing="isEditing"
                              CourseStartDate="course?.StartDate"
                              Module="editingModule"
                              OnSave="SaveModule" />
            }
        </main>
    </div>
</div>

@code {
    [Parameter] public int? CourseId { get; set; }

    private bool isTeacher, isDialogOpen, isEditing;
    private Dictionary<int, int> gradientIndex = new();

    private CourseDto? course;
    private bool isLoading = true;
    private string? errorMessage;

    private ModuleDto editingModule = new() { Id = 0, Name = "", Description = "", CourseId = 0, CourseName = "", StartDate = DateTime.Now };

    private List<ModuleDto> modules = [];

    protected override async Task OnParametersSetAsync()
    {
        await LoadModulesAsync();
    }

    private async Task LoadModulesAsync()
    {
        isLoading = true;
        errorMessage = null;
        StateHasChanged();
        try
        {
            int targetCourseId;

            if (CourseId.HasValue)
            {
                targetCourseId = CourseId.Value;
            }
            else
            {
                var myCourse = await ApiService.GetAsync<CourseDto>("api/studentcourse/mycourse");
                if (myCourse is not null && myCourse.Id > 0)
                {
                    targetCourseId = myCourse.Id;
                }
                else
                {
                    errorMessage = "No course specified and you are not enrolled in any course.";
                    return;
                }
            }

            course = await CourseService.GetCourseByIdAsync(targetCourseId);
            var detail = await CourseService.GetCourseDetailByIdAsync(targetCourseId);

            if (detail is not null)
            {
                modules = detail.Modules ?? new List<ModuleDto>();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load modules: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleRole() => isTeacher = !isTeacher;
    private void CycleGradient(int id) => gradientIndex[id] = (gradientIndex.GetValueOrDefault(id, id % ModuleStyles.Gradients.Length) + 1) % ModuleStyles.Gradients.Length;
    
    private async Task DeleteModule(int id)
    {
        try
        {
            await ModuleService.DeleteModuleAsync(id);
            await LoadModulesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to delete module: {ex.Message}";
        }
    }

    private void ViewActivities(int id) { /* NavigationManager.NavigateTo(...) */ }
    private bool IsActive(ModuleDto m) => m.StartDate <= DateTime.Now && (!m.EndDate.HasValue || m.EndDate >= DateTime.Now);

    private void OpenCreateDialog()
    {
        isEditing = false;
        editingModule = new() { Id = 0, Name = "", Description = "", CourseId = course?.Id ?? CourseId ?? 0, CourseName = course?.Name ?? "", StartDate = DateTime.Now };
        isDialogOpen = true;
    }

    private void OpenEditDialog(ModuleDto m) { isEditing = true; editingModule = m with { }; isDialogOpen = true; }

    private async Task SaveModule()
    {
        try
        {
            if (isEditing)
            {
                var updateDto = new UpdateModuleDto
                {
                    Name = editingModule.Name,
                    Description = editingModule.Description,
                    StartDate = editingModule.StartDate,
                    EndDate = editingModule.EndDate ?? editingModule.StartDate.AddDays(7),
                    Icon = editingModule.Icon
                };
                await ModuleService.UpdateModuleAsync(editingModule.Id, updateDto);
            }
            else
            {
                var createDto = new CreateModuleDto
                {
                    CourseId = editingModule.CourseId,
                    Name = editingModule.Name,
                    Description = editingModule.Description,
                    StartDate = editingModule.StartDate,
                    EndDate = editingModule.EndDate ?? editingModule.StartDate.AddDays(7),
                    Icon = editingModule.Icon
                };
                await ModuleService.CreateModuleAsync(createDto);
            }

            isDialogOpen = false;
            await LoadModulesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to save module: {ex.Message}";
        }
    }

}