@page "/student/activities"
@using BlazorBlueprint.Components
@using LMS.Blazor.Client.Components
@using LMS.Shared.DTOs.Activity
@inject IActivityService ActivityService

<PageTitle>Activities</PageTitle>

<div>
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2 text-muted">Loading activities...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(loadError))
    {
        <div class="alert alert-danger">
            <p>@loadError</p>
            <button class="btn btn-outline-danger btn-sm" @onclick="LoadActivitiesAsync">Retry</button>
        </div>
    }
    else if (!activities.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-journal-x fs-1"></i>
            <p class="mt-2">No activities found. Create your first activity.</p>
        </div>
    }
    else
    {
        <ActivityListComponent Activities = "activities"/>

        @if (totalPages > 1)
        {
            <nav class="mt-3">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => GoToPageAsync(currentPage - 1)">Previous</button>
                    </li>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        var pageNum = i;
                        <li class="page-item @(currentPage == pageNum ? "active" : "")">
                            <button class="page-link" @onclick="() => GoToPageAsync(pageNum)">@pageNum</button>
                        </li>
                    }
                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="() => GoToPageAsync(currentPage + 1)">Next</button>
                    </li>
                </ul>
            </nav>
        }
    }
</div>

@code {
    private List<ActivityDto> activities = [];
    private bool isLoading;
    private string? errorMessage;
    private string? successMessage;
    private string? loadError;

    // Pagination state
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalCount = 0;
    private int totalPages = 0;

    protected override async Task OnInitializedAsync()
        => await LoadActivitiesAsync();

    private async Task LoadActivitiesAsync()
    {
        isLoading = true;
        loadError = null;
        StateHasChanged();

        try
        {
            var result = await ActivityService.GetAllActivitiesAsync(
                currentPage, 
                pageSize, 
                1
            );

            if (result is not null)
            {
                activities = result.Items;
                totalCount = result.TotalCount;
                totalPages = result.TotalPages;
            }
        }
        catch (Exception ex)
        {
            loadError = $"Failed to load activities. {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task GoToPageAsync(int page)
    {
        currentPage = page;
        await LoadActivitiesAsync();
    }
}