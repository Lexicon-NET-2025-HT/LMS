@page "/admin/activities/{ActivityId:int}/details"
@attribute [Authorize(Roles = "Teacher")]
@using LMS.Blazor.Client.Components
@using LMS.Blazor.Client.Components.Activity
@using LMS.Shared.DTOs.Activity
@using LMS.Shared.DTOs.ActivityType
@using LMS.Shared.DTOs.Document
@using LMS.Shared.DTOs.Submission
@using LMS.Blazor.Client.Uploads
@using LMS.Blazor.Client.Components.Document
@inject IActivityService ActivityService
@inject IActivityTypeService ActivityTypeService
@inject IDocumentService DocumentService
@inject ISubmissionService SubmissionService
@inject NavigationManager Navigation

<PageTitle>Activity Details</PageTitle>

<div class="container-fluid py-4">

    @* ---- Header ---- *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
        <h2 class="mb-0">Activity Details</h2>
        <div class="d-flex gap-2 flex-wrap align-items-center">
            @if (activity is not null)
            {
                <button class="btn btn-sm btn-outline-secondary" @onclick="OpenActivityTypeDialog">
                    <i class="bi bi-tag"></i>
                    <span class="d-none d-md-inline ms-1">Add Type</span>
                </button>
                <button class="btn btn-sm btn-primary" @onclick="OpenEditDialog">
                    <i class="bi bi-pencil"></i>
                    <span class="d-none d-md-inline ms-1">Edit Activity</span>
                </button>
            }
            <button class="btn btn-outline-secondary" @onclick="GoBack">
                <i class="bi bi-arrow-left"></i>
                <span class="d-none d-md-inline ms-1">Back to Module</span>
            </button>
        </div>
    </div>

    @* ---- Feedback ---- *@
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @successMessage
            <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
        </div>
    }

    @* ---- Loading / error / not found ---- *@
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2 text-muted">Loading activity details...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(loadError))
    {
        <div class="alert alert-danger">
            <p>@loadError</p>
            <button class="btn btn-outline-danger btn-sm" @onclick="LoadActivityAsync">Retry</button>
        </div>
    }
    else if (activity is null)
    {
        <div class="alert alert-warning">Activity not found.</div>
    }
    else
    {
        @* ==============================
           ACTIVITY INFO CARD
           ============================== *@
        <div class="card mb-4">
            <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
                <h5 class="mb-0">@activity.Name</h5>
                <div class="d-flex gap-2 flex-wrap align-items-center">
                    <span class="badge @ActivityHelpers.GetActivityTypeBadge(activity.ActivityTypeName) fs-6">@activity.ActivityTypeName</span>
                    <span class="badge bg-secondary">@submissions.Count Submissions</span>
                    <span class="badge bg-info text-dark">@documents.Count Documents</span>
                </div>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <p class="text-muted mb-1 small">Module</p>
                        <p class="mb-0 fw-semibold">@activity.ModuleName</p>
                    </div>
                    <div class="col-md-4">
                        <p class="text-muted mb-1 small">Description</p>
                        <p class="mb-0">@(string.IsNullOrEmpty(activity.Description) ? "—" : activity.Description)</p>
                    </div>
                    <div class="col-md-2 col-6">
                        <p class="text-muted mb-1 small">Start</p>
                        <p class="mb-0">@activity.StartTime?.ToString("yyyy-MM-dd HH:mm")</p>
                    </div>
                    <div class="col-md-2 col-6">
                        <p class="text-muted mb-1 small">End / Deadline</p>
                        <p class="mb-0 @(activity.EndTime < DateTime.Now ? "text-danger fw-semibold" : "")">
                            @activity.EndTime.ToString("yyyy-MM-dd HH:mm")
                            @if (activity.EndTime < DateTime.Now)
                            {
                                <span class="badge bg-danger ms-1">Past</span>
                            }
                        </p>
                    </div>
                </div>
            </div>
        </div>

        @* ==============================
           SUBMISSIONS SECTION
           ============================== *@
        @if (activity?.ActivityTypeName == "Assignment")
        {
            <div class="card mb-4">
                <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
                    <div class="d-flex align-items-center gap-3 flex-wrap">
                        <h6 class="mb-0"><i class="bi bi-send me-2"></i>Submissions</h6>
                        @if (submissions.Any())
                        {
                            <span class="badge bg-danger">@submissions.Count(s => s.IsLate) Late</span>
                        }
                    </div>
                    <div style="min-width:260px;">
                        <input class="form-control form-control-sm"
                               placeholder="Search by student name or ID"
                               @bind="studentFilter"
                               @bind:event="oninput" />
                    </div>
                </div>

                <div class="card-body p-0">
                    @if (!FilteredSubmissions.Any())
                    {
                        <p class="text-muted p-3 mb-0">
                            @(string.IsNullOrWhiteSpace(studentFilter)
                                ? "No submissions yet for this activity."
                                : "No submissions match that student filter.")
                        </p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Student</th>
                                        <th class="d-none d-md-table-cell">Submitted</th>
                                        <th class="d-none d-sm-table-cell">Status</th>
                                        <th class="d-none d-lg-table-cell">Body</th>
                                        <th>Feedback</th>
                                        <th style="width:80px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var sub in FilteredSubmissions)
                                    {
                                        <tr class="@(expandedSubmissionId == sub.Id ? "table-active" : "")">
                                            <td>
                                                <div class="fw-semibold">@sub.StudentName</div>
                                                <div class="text-muted small">@sub.StudentId</div>
                                            </td>
                                            <td class="d-none d-md-table-cell text-muted small">
                                                @sub.SubmittedAt.ToString("yyyy-MM-dd HH:mm")
                                            </td>
                                            <td class="d-none d-sm-table-cell">
                                                @if (sub.IsLate)
                                                {
                                                    <span class="badge bg-danger">Late</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success">On time</span>
                                                }
                                            </td>
                                            <td class="d-none d-lg-table-cell">
                                                @if (!string.IsNullOrEmpty(sub.Body))
                                                {
                                                    <span class="text-truncate d-inline-block" style="max-width:180px;">@sub.Body</span>
                                                }
                                                else if (sub.DocumentId is not null)
                                                {
                                                    <span class="text-muted small"><i class="bi bi-file-earmark me-1"></i>Attachment</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">—</span>
                                                }
                                            </td>
                                            <td>
                                                @if (sub.CommentCount > 0)
                                                {
                                                    <span class="badge bg-info text-dark">@sub.CommentCount</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">None</span>
                                                }
                                            </td>
                                            <td class="text-end text-nowrap">
                                                <button class="btn btn-sm @(expandedSubmissionId == sub.Id ? "btn-primary" : "btn-outline-primary")"
                                                        title="@(expandedSubmissionId == sub.Id ? "Collapse" : "Review")"
                                                        @onclick="() => ToggleSubmission(sub.Id)">
                                                    <i class="bi bi-@(expandedSubmissionId == sub.Id ? "chevron-up" : "chat-left-text")"></i>
                                                </button>
                                            </td>
                                        </tr>

                                        @* ---- Expanded feedback panel ---- *@
                                        @if (expandedSubmissionId == sub.Id)
                                        {
                                            <tr class="table-active">
                                                <td colspan="7" class="pt-0">
                                                    <div class="bg-white border rounded p-3 mt-1">
                                                        <div class="row g-3">
                                                            <div class="col-md-6">
                                                                <p class="small fw-semibold text-muted mb-1">Submission Content</p>
                                                                @if (!string.IsNullOrEmpty(sub.Body))
                                                                {
                                                                    <div class="border rounded p-2 bg-light small mb-2" style="white-space:pre-wrap;">@sub.Body</div>
                                                                }
                                                                
                                                                @if (sub.Document is not null)
                                                                {
                                                                    <div class="border rounded p-3 bg-light mb-2">
                                                                        <div class="small text-muted mb-1">Attached file</div>
                                                                        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                                                                            <div>
                                                                                <div class="fw-semibold">@sub.Document.DisplayName</div>
                                                                                @if (!string.IsNullOrWhiteSpace(sub.Document.Description))
                                                                                {
                                                                                    <div class="text-muted small">@sub.Document.Description</div>
                                                                                }
                                                                            </div>
                                                                            <a class="btn btn-sm btn-primary"
                                                                               href="@DocumentService.GetDocumentFileUrl(sub.Document.Id, true)"
                                                                               target="_blank">
                                                                                <i class="bi bi-download me-1"></i>Download file
                                                                            </a>
                                                                        </div>
                                                                    </div>
                                                                }
                                                                
                                                                @if (string.IsNullOrEmpty(sub.Body) && sub.Document is null)
                                                                {
                                                                    <p class="text-muted small">No content provided.</p>
                                                                }
                                                            </div>
                                                            <div class="col-md-6">
                                                                <p class="small fw-semibold text-muted mb-1">Feedback</p>
                                                                @if (loadingSubmissionDetailId == sub.Id)
                                                                {
                                                                    <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                                                                }
                                                                else if (submissionDetails.TryGetValue(sub.Id, out var detail))
                                                                {
                                                                    @if (detail.Comments.Any())
                                                                    {
                                                                        <div class="mb-3">
                                                                            @foreach (var c in detail.Comments.OrderBy(c => c.CreatedAt))
                                                                            {
                                                                                <div class="border rounded p-2 @(c.AuthorId == sub.StudentId ? "bg-warning bg-opacity-10" : "bg-light") small mb-2">
                                                                                    <div class="d-flex justify-content-between mb-1">
                                                                                        <span class="fw-semibold">@(c.AuthorId == sub.StudentId ? $"{c.AuthorName} (Resubmission)" : c.AuthorName)</span>
                                                                                        <span class="text-muted" style="font-size: 0.75rem;">@c.CreatedAt.ToString("g")</span>
                                                                                    </div>
                                                                                    <div style="white-space:pre-wrap;">@c.Text</div>
                                                                                    @if (c.AuthorId == sub.StudentId && sub.Document is not null)
                                                                                    {
                                                                                        <div class="mt-2">
                                                                                            <a class="btn btn-sm btn-outline-primary"
                                                                                               href="@DocumentService.GetDocumentFileUrl(sub.Document.Id, true)"
                                                                                               target="_blank">
                                                                                                <i class="bi bi-download me-1"></i>Download current file
                                                                                            </a>
                                                                                        </div>
                                                                                    }
                                                                                </div>
                                                                            }
                                                                        </div>
                                                                    }
                                                                    
                                                                    <div class="d-flex flex-column gap-2">
                                                                        <textarea class="form-control form-control-sm"
                                                                                  rows="3"
                                                                                  placeholder="Write feedback..."
                                                                                  @bind="feedbackDrafts[sub.Id]"
                                                                                  @bind:event="oninput"></textarea>
                                                                        <button class="btn btn-sm btn-primary align-self-end"
                                                                                disabled="@string.IsNullOrWhiteSpace(feedbackDrafts[sub.Id])"
                                                                                @onclick="() => SendFeedbackAsync(sub.Id)">
                                                                            <i class="bi bi-send me-1"></i>Send Feedback
                                                                        </button>
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        }

        @* ==============================
           DOCUMENTS SECTION
           ============================== *@
        <div class="card mb-4">
            <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
                <h6 class="mb-0"><i class="bi bi-file-earmark me-2"></i>Documents</h6>
                <button class="btn btn-sm btn-primary"
                        @onclick="() => showUploadDocument = !showUploadDocument">
                    <i class="bi bi-upload"></i>
                    <span class="d-none d-md-inline ms-1">Upload Document</span>
                </button>
            </div>

            @if (showUploadDocument)
            {
                <div class="card-body border-bottom bg-light">
                    <UploadDocumentField 
                        Label="Select Document"
                        @bind-Value="documentUpload"
                        HandleSubmit="SaveDocumentAsync" />
                </div>
            }

            <div class="card-body p-0">
                @if (!documents.Any())
                {
                    <p class="text-muted p-3 mb-0">No documents attached to this activity yet.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                             <thead class="table-light">
                                <tr>
                                    <th style="width:100%"></th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var doc in documents)
                                {
                                    <tr>
                                        <td class="align-middle" colspan="4">
                                            <DocumentWithDownload Document="doc" />
                                        </td>
                                        <td class="align-middle text-end pe-3">
                                            <button class="btn btn-sm btn-outline-danger"
                                                    @onclick="() => HandleDeleteDocument(doc)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@* ---- Edit Activity dialog (reuses the shared ActivityDialog with module selection hidden) ---- *@
<ActivityDialog @bind-Open="editDialogOpen"
                IsEditing="true"
                HideModuleSelection="true"
                Model="editFormModel"
                ActivityTypes="activityTypes"
                OnSave="HandleEditSave"
                OnAddActivityType="OpenActivityTypeDialog"
                OnDeleteActivityType="HandleDeleteActivityType"
                ActivityTypeError="@activityTypeError" />

@* ---- Activity Type dialog ---- *@
<ActivityTypeDialog @bind-Open="activityTypeDialogOpen"
                    @bind-Name="newActivityTypeName"
                    @bind-Description="newActivityTypeDescription"
                    Error="@activityTypeError"
                    IsSaving="isCreatingActivityType"
                    OnSave="HandleCreateActivityType"
                    OnCancel="() => activityTypeError = null" />

@* ---- Delete Document modal ---- *@
@if (showDeleteDocumentConfirm && documentToDelete is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                </div>
                <div class="modal-body">
                    Are you sure you want to remove <strong>@documentToDelete.DisplayName</strong>?
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showDeleteDocumentConfirm = false">Cancel</button>
                    <button class="btn btn-danger" @onclick="ConfirmDeleteDocumentAsync">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int ActivityId { get; set; }

    // ---- Data ----
    private ActivityDetailDto? activity;
    private List<SubmissionDto> submissions = [];
    private List<DocumentDto> documents = [];
    private List<ActivityTypeDto> activityTypes = [];

    // ---- Page state ----
    private bool isLoading;
    private string? loadError;
    private string? successMessage;
    private string? errorMessage;

    // ---- Submissions ----
    private int? expandedSubmissionId;
    private string studentFilter = string.Empty;

    // ---- Edit dialog ----
    private bool editDialogOpen;
    private ActivityDialog.ActivityFormModel editFormModel = new();

    // ---- Activity Type dialog ----
    private bool activityTypeDialogOpen;
    private string newActivityTypeName = string.Empty;
    private string newActivityTypeDescription = string.Empty;
    private string? activityTypeError;
    private bool isCreatingActivityType;

    // ---- Documents ----
    private bool showUploadDocument;
    private bool showDeleteDocumentConfirm;
    private DocumentDto? documentToDelete;
    private UploadDocumentValue documentUpload = new();

    // ---- Feedback drafts ----
    private Dictionary<int, string> feedbackDrafts = new();
    private Dictionary<int, SubmissionDetailDto> submissionDetails = new();
    private int? loadingSubmissionDetailId;

    // ---- Lifecycle ----
    protected override async Task OnInitializedAsync()
        => await LoadActivityAsync();

    private IEnumerable<SubmissionDto> FilteredSubmissions =>
        submissions.Where(s =>
            string.IsNullOrWhiteSpace(studentFilter) ||
            s.StudentName.Contains(studentFilter, StringComparison.OrdinalIgnoreCase) ||
            s.StudentId.Contains(studentFilter, StringComparison.OrdinalIgnoreCase));

    private async Task LoadActivityAsync()
    {
        isLoading = true;
        loadError = null;
        StateHasChanged();

        try
        {
            var typesResult = await ActivityTypeService.GetAllActivityTypesAsync();
            activityTypes = typesResult?.ToList() ?? [];

            var response = await ActivityService.GetActivityByIdAsync(ActivityId);
            if (response is not null)
            {
                activity = new ActivityDetailDto
                {
                    Id               = response.Id,
                    ModuleId         = response.ModuleId,
                    ModuleName       = response.ModuleName,
                    Name             = response.Name,
                    Description      = response.Description,
                    ActivityTypeId   = response.ActivityTypeId,
                    ActivityTypeName = response.ActivityTypeName,
                    StartTime        = response.StartTime,
                    EndTime          = response.EndTime,
                    DocumentCount    = response.DocumentCount,
                    SubmissionCount  = response.SubmissionCount,
                    Documents        = response.Documents?.ToList() ?? [],
                    Submissions      = response.Submissions?.ToList() ?? []
                };

                submissions = activity.Submissions;
                documents   = activity.Documents;

                // Seed feedback draft slots
                foreach (var s in submissions)
                    feedbackDrafts.TryAdd(s.Id, string.Empty);
            }
        }
        catch (Exception ex)
        {
            loadError = $"Failed to load activity. {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    // ---- Edit dialog ----

    private void OpenEditDialog()
    {
        activityTypeError = null;
        if (activity is null) return;

        editFormModel = new()
        {
            ModuleId       = activity.ModuleId,
            Name           = activity.Name,
            Description    = activity.Description,
            ActivityTypeId = activity.ActivityTypeId,
            StartTime      = activity.StartTime,
            EndTime        = activity.EndTime
        };

        editDialogOpen = true;
    }

    private async Task HandleEditSave()
    {
        if (activity is null) return;

        try
        {
            await ActivityService.UpdateActivityAsync(activity.Id, new UpdateActivityDto
            {
                Name           = editFormModel.Name,
                Description    = editFormModel.Description,
                ActivityTypeId = editFormModel.ActivityTypeId,
                StartTime      = editFormModel.StartTime ?? DateTime.Now,
                EndTime        = editFormModel.EndTime
            });

            editDialogOpen = false;
            successMessage = "Activity updated successfully.";
            await LoadActivityAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to update activity. {ex.Message}";
        }
    }

    // ---- Activity Type dialog ----

    private void OpenActivityTypeDialog()
    {
        newActivityTypeName = string.Empty;
        newActivityTypeDescription = string.Empty;
        activityTypeError = null;
        activityTypeDialogOpen = true;
    }

    private async Task HandleCreateActivityType()
    {
        activityTypeError = null;

        if (string.IsNullOrWhiteSpace(newActivityTypeName))
        {
            activityTypeError = "Please enter an activity type name.";
            return;
        }
        if (string.IsNullOrWhiteSpace(newActivityTypeDescription))
        {
            activityTypeError = "Please enter an activity type description.";
            return;
        }

        isCreatingActivityType = true;
        try
        {
            var created = await ActivityTypeService.CreateActivityTypeAsync(new CreateActivityTypeDto
            {
                Name        = newActivityTypeName.Trim(),
                Description = newActivityTypeDescription
            });

            if (created is null)
            {
                activityTypeError = "Failed to create activity type.";
                return;
            }

            var typesResult = await ActivityTypeService.GetAllActivityTypesAsync();
            activityTypes = typesResult?.ToList() ?? [];

            // Pre-select the new type in the edit form if it's open
            editFormModel.ActivityTypeId = created.Id;

            activityTypeDialogOpen = false;
            newActivityTypeName = string.Empty;
            newActivityTypeDescription = string.Empty;
            successMessage = $"Activity type '{created.Name}' created.";
        }
        catch (Exception ex)
        {
            activityTypeError = $"Failed to create activity type. {ex.Message}";
        }
        finally
        {
            isCreatingActivityType = false;
        }
    }

    private async Task HandleDeleteActivityType(int activityTypeId)
    {
        try
        {
            await ActivityTypeService.DeleteActivityTypeAsync(activityTypeId);
            var typesResult = await ActivityTypeService.GetAllActivityTypesAsync();
            activityTypes = typesResult?.ToList() ?? [];
            editFormModel.ActivityTypeId = 0;
        }
        catch (Exception ex)
        {
            activityTypeError = $"Cannot delete this activity type: {ex.Message}";
        }
    }

    // ---- Toggle submission row ----
    private async Task ToggleSubmission(int submissionId)
    {
        if (expandedSubmissionId == submissionId)
        {
            expandedSubmissionId = null;
            return;
        }

        expandedSubmissionId = submissionId;

        if (!submissionDetails.ContainsKey(submissionId))
        {
            loadingSubmissionDetailId = submissionId;
            StateHasChanged();
            
            var detail = await SubmissionService.GetSubmissionDetailByIdAsync(submissionId);
            if (detail is not null)
            {
                submissionDetails[submissionId] = detail;
            }
            loadingSubmissionDetailId = null;
        }

        if (!feedbackDrafts.ContainsKey(submissionId))
        {
            feedbackDrafts[submissionId] = string.Empty;
        }
    }

    private async Task SendFeedbackAsync(int submissionId)
    {
        if (!feedbackDrafts.TryGetValue(submissionId, out var draft) || string.IsNullOrWhiteSpace(draft))
            return;

        try
        {
            await SubmissionService.SubmitCommentAsync(submissionId, new SubmitCommentDto { CommentText = draft });
            feedbackDrafts[submissionId] = string.Empty;
            
            // Reload the detailed submission to show the new comment
            var detail = await SubmissionService.GetSubmissionDetailByIdAsync(submissionId);
            if (detail is not null)
            {
                submissionDetails[submissionId] = detail;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to save feedback: {ex.Message}";
        }
    }

    private async Task SaveDocumentAsync()
    {
        var createdDocument = await DocumentService.CreateDocumentAsync(new CreateDocumentDto
        {
            ActivityId = ActivityId,
            Description = documentUpload.Description
        }, documentUpload);

        if (createdDocument is not null)
        {
            documents.Add(createdDocument);
            successMessage = $"Document '{createdDocument.DisplayName}' uploaded.";
            documentUpload = new UploadDocumentValue();
            showUploadDocument = false;
        }
        else
        {
            errorMessage = "Failed to upload document. Please try again.";
        }
    }

    // ---- Document actions ----
    private void HandleDeleteDocument(DocumentDto doc)
    {
        documentToDelete = doc;
        showDeleteDocumentConfirm = true;
    }

    private async Task ConfirmDeleteDocumentAsync()
    {
        if (documentToDelete is null) return;

        await DocumentService.DeleteDocumentAsync(documentToDelete.Id);
        documents.RemoveAll(d => d.Id == documentToDelete.Id);
        successMessage = $"Document '{documentToDelete.DisplayName}' removed.";
        documentToDelete = null;
        showDeleteDocumentConfirm = false;
        await Task.CompletedTask;
    }

    // ---- Helpers ----

    private void GoBack()
    {
        if (activity is not null)
            Navigation.NavigateTo($"/admin/modules/{activity.ModuleId}/details");
        else
            Navigation.NavigateTo("/admin/modules");
    }

    public static class ActivityHelpers
    {
        public static string GetActivityTypeBadge(string? typeName) => typeName switch
        {
            "Assignment" => "bg-warning text-dark",
            "Exercise" => "bg-danger",
