@page "/admin/activities"
@attribute [Authorize(Roles = "Teacher")]
@using LMS.Blazor.Client.Components.Activity

<PageTitle>Activity Management</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
        <h2 class="mb-0">Activity Management</h2>
    </div>

    <ActivityFilter SelectedCourseId="@selectedCourseId"
                    SelectedModuleId="@selectedModuleId"
                    SelectedCourseIdChanged="OnCourseChanged"
                    SelectedModuleIdChanged="OnModuleChanged" />

    <ActivityGrid ShowCreate="true"
                  ShowEdit="true"
                  SelectedCourseId="@selectedCourseId"
                  SelectedModuleId="@selectedModuleId" />
</div>

@code {
    private int selectedCourseId;
    private int selectedModuleId;

    private Task OnCourseChanged(int courseId)
    {
        selectedCourseId = courseId;
        selectedModuleId = 0;
        return Task.CompletedTask;
    }

    private Task OnModuleChanged(int moduleId)
    {
        selectedModuleId = moduleId;
        return Task.CompletedTask;
    }
}