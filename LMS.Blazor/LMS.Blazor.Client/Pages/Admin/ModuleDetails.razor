@page "/admin/modules/{ModuleId:int}/details"
@page "/modules/{ModuleId:int}/details"
@attribute [Authorize(Roles = "Teacher,Student")]
@using LMS.Blazor.Client.Components
@using LMS.Blazor.Client.Components.Activity
@using LMS.Blazor.Client.Uploads
@using LMS.Shared.DTOs.Activity
@using LMS.Shared.DTOs.ActivityType
@using LMS.Shared.DTOs.Document
@using LMS.Shared.DTOs.Module
@inject IActivityTypeService ActivityTypeService
@inject IModuleService ModuleService
@inject IActivityService ActivityService
@inject IDocumentService DocumentService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IDocumentService DocumentService

<PageTitle>Module Details</PageTitle>

<div class="container-fluid py-4">

    @* ---- Header ---- *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
        <h2 class="mb-0">Module Details</h2>
        <button class="btn btn-outline-secondary" @onclick="GoBack">
            <i class="bi bi-arrow-left"></i>
            <span class="d-none d-md-inline ms-1">Back to Modules</span>
        </button>
    </div>

    @* ---- Feedback ---- *@
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @successMessage
            <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
        </div>
    }

    @* ---- Loading / error / not found ---- *@
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2 text-muted">Loading module details...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(loadError))
    {
        <div class="alert alert-danger">
            <p>@loadError</p>
            <button class="btn btn-outline-danger btn-sm" @onclick="LoadModuleAsync">Retry</button>
        </div>
    }
    else if (module is null)
    {
        <div class="alert alert-warning">Module not found.</div>
    }
    else
    {
        @* ==============================
           MODULE INFO CARD
           ============================== *@
        <div class="card mb-4">
            <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
                <h5 class="mb-0">@module.Name</h5>
                <div class="d-flex gap-2 flex-wrap">
                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25">
                        @module.CourseName
                    </span>
                    <span class="badge bg-secondary">@activities.Count Activities</span>
                    <span class="badge bg-info text-dark">@documents.Count Documents</span>
                </div>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-5">
                        <p class="text-muted mb-1 small">Description</p>
                        <p class="mb-0">@(string.IsNullOrEmpty(module.Description) ? "—" : module.Description)</p>
                    </div>
                    <div class="col-md-3 col-6">
                        <p class="text-muted mb-1 small">Start Date</p>
                        <p class="mb-0">@module.StartDate.ToString("yyyy-MM-dd")</p>
                    </div>
                    <div class="col-md-3 col-6">
                        <p class="text-muted mb-1 small">End Date</p>
                        <p class="mb-0">@module.EndDate.ToString("yyyy-MM-dd")</p>
                    </div>
                </div>
            </div>
        </div>

        @* ==============================
           ACTIVITIES SECTION
           ============================== *@
        <div class="card mb-4">
            <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
                <h6 class="mb-0"><i class="bi bi-lightning me-2"></i>Activities</h6>
                @if (isTeacher)
                {
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-primary" @onclick="OpenCreateActivityDialog">
                            <i class="bi bi-plus-lg"></i>
                            <span class="d-none d-md-inline ms-1">Add Activity</span>
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="OpenActivityTypeDialog">
                            <i class="bi bi-tag"></i>
                            <span class="d-none d-md-inline ms-1">Add Type</span>
                        </button>
                    </div>
                }
            </div>

            @* ActivityTypeDialog is used both from the header button
               and from the Add/Edit Type button inside ActivityDialog *@
            <ActivityTypeDialog @bind-Open="activityTypeDialogOpen"
                                @bind-Name="newActivityTypeName"
                                @bind-Description="newActivityTypeDescription"
                                Error="@activityTypeError"
                                IsSaving="isCreatingActivityType"
                                OnSave="HandleCreateActivityType"
                                OnCancel="() => activityTypeError = null"/>

            @* ---- Activity table ---- *@
            <div class="card-body p-0">
                @if (!activities.Any())
                {
                    <p class="text-muted p-3 mb-0">No activities yet. Add the first one.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Name</th>
                                    <th>Type</th>
                                    <th class="d-none d-sm-table-cell">Start</th>
                                    <th class="d-none d-sm-table-cell">End</th>
                                    <th class="text-center d-none d-md-table-cell">Docs</th>
                                    <th class="text-center d-none d-md-table-cell">Submissions</th>
                                    <th style="width:120px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var act in activities)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@act.Name</div>
                                            @if (!string.IsNullOrEmpty(act.Description))
                                            {
                                                <div class="text-muted small text-truncate" style="max-width:200px;">@act.Description</div>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge @ActivityHelpers.GetActivityTypeBadge(act.ActivityTypeName)">@act.ActivityTypeName</span>
                                        </td>
                                        <td class="d-none d-sm-table-cell text-muted small">@act.StartTime?.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td class="d-none d-sm-table-cell text-muted small">@act.EndTime.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td class="text-center d-none d-md-table-cell">
                                            <span class="badge bg-info text-dark">@act.DocumentCount</span>
                                        </td>
                                        <td class="text-center d-none d-md-table-cell">
                                            <span class="badge bg-warning text-dark">@act.SubmissionCount</span>
                                        </td>
                                        <td class="text-end text-nowrap">
                                            <button class="btn btn-sm btn-outline-primary me-1"
                                                    title="View Details"
                                                    @onclick="() => Navigation.NavigateTo(getURL(act.Id))">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            @if (isTeacher)
                                            {
                                                <button class="btn btn-sm btn-outline-secondary me-1"
                                                        title="Edit"
                                                        @onclick="() => OpenEditActivityDialog(act)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger"
                                                        title="Delete"
                                                        @onclick="() => HandleDeleteActivity(act)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        @* ==============================
           DOCUMENTS SECTION
           ============================== *@
        <div class="card mb-4">
            <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
                <h6 class="mb-0"><i class="bi bi-file-earmark me-2"></i>Documents</h6>
                @if (isTeacher)
                {
                    <button class="btn btn-sm btn-primary"
                            title="Upload Document"
                            @onclick="() => showUploadDocument = !showUploadDocument">
                        <i class="bi bi-upload"></i>
                        <span class="d-none d-md-inline ms-1">Upload Document</span>
                    </button>
                }
            </div>

            @if (showUploadDocument)
            {
                <div class="card-body border-bottom bg-light">
                    <UploadDocumentField 
                        Label="Select Document"
                        @bind-Value="documentUpload"
                        HandleSubmit="SaveDocumentAsync" />
                </div>
            }

            <div class="card-body p-0">
                @if (!documents.Any())
                {
                    <p class="text-muted p-3 mb-0">No documents attached to this module yet.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:100%"></th> @* force minimize second column *@
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var doc in documents)
                                {
                                    <tr>
                                        <td class="align-middle">
                                            <DocumentWithDownload Document="doc" />
                                        </td>
                                        <td class="align-middle">
                                            <button class="btn btn-sm btn-outline-danger"
                                                    title="Delete"
                                                    @onclick="() => HandleDeleteDocument(doc)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@* ---- Add / Edit Activity dialog ---- *@
<ActivityDialog @bind-Open="dialogOpen"
                IsEditing="isEditing"
                HideModuleSelection="true"
                Model="formModel"
                ActivityTypes="activityTypes"
                OnSave="HandleActivitySave"
                OnAddActivityType="OpenActivityTypeDialog"
                OnDeleteActivityType="HandleDeleteActivityType"
                ActivityTypeError="@activityTypeError" />

@* ---- Delete Activity modal ---- *@
@if (showDeleteActivityConfirm && activityToDelete is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                </div>
                <div class="modal-body">
                    Are you sure you want to delete activity <strong>@activityToDelete.Name</strong>?
                    All associated submissions will also be removed. This cannot be undone.
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => { showDeleteActivityConfirm = false; activityToDelete = null; }">Cancel</button>
                    <button class="btn btn-danger" @onclick="ConfirmDeleteActivityAsync" disabled="@isDeletingActivity">
                        @if (isDeletingActivity)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ---- Delete Document modal ---- *@
@if (showDeleteDocumentConfirm && documentToDelete is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                </div>
                <div class="modal-body">
                    Are you sure you want to remove <strong>@documentToDelete.DisplayName</strong>?
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showDeleteDocumentConfirm = false">Cancel</button>
                    <button class="btn btn-danger" @onclick="ConfirmDeleteDocumentAsync">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int ModuleId { get; set; }

    // ---- Data ----
    private ModuleDetailDto? module;
    private List<ActivityDto> activities = [];
    private List<DocumentDto> documents = [];
    private List<ActivityTypeDto> activityTypes = [];
    private bool isTeacher;

    // ---- Page state ----
    private bool isLoading;
    private string? loadError;
    private string? successMessage;
    private string? errorMessage;

    // ---- Activity dialog (shared for create & edit) ----
    private bool dialogOpen;
    private bool isEditing;
    private ActivityDto? editingActivity;
    private ActivityDialog.ActivityFormModel formModel = new();

    // ---- Delete activity ----
    private bool showDeleteActivityConfirm;
    private bool isDeletingActivity;
    private ActivityDto? activityToDelete;

    // ---- Activity Type dialog ----
    private bool activityTypeDialogOpen;
    private string newActivityTypeName = string.Empty;
    private string newActivityTypeDescription = string.Empty;
    private string? activityTypeError;
    private bool isCreatingActivityType;

    // ---- Documents ----
    private bool showUploadDocument;
    private bool showDeleteDocumentConfirm;
    private DocumentDto? documentToDelete;
    private UploadDocumentValue documentUpload = new();

    // ---- Lifecycle ----
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isTeacher = authState.User.IsInRole("Teacher");
        await LoadModuleAsync();
    }

    private async Task LoadModuleAsync()
    {
        isLoading = true;
        loadError = null;
        documentUpload = new UploadDocumentValue();
        StateHasChanged();

        try
        {
            var typesResult = await ActivityTypeService.GetAllActivityTypesAsync();
            activityTypes = typesResult?.ToList() ?? [];

            module = await ModuleService.GetModuleDetailByIdAsync(ModuleId);
            if (module is not null)
            {
                activities = module.Activities;
                documents = module.Documents;
            }
        }
        catch (Exception ex)
        {
            loadError = $"Failed to load module. {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    // ---- Activity dialog actions ----

    private void OpenCreateActivityDialog()
    {
        activityTypeError = null;
        isEditing = false;
        editingActivity = null;
        formModel = new()
        {
            ModuleId = ModuleId,
            ActivityTypeId = activityTypes.FirstOrDefault()?.Id ?? 0
        };
        dialogOpen = true;
    }

    private void OpenEditActivityDialog(ActivityDto act)
    {
        activityTypeError = null;
        isEditing = true;
        editingActivity = act;
        formModel = new()
        {
            ModuleId = act.ModuleId,
            Name = act.Name,
            Description = act.Description,
            ActivityTypeId = act.ActivityTypeId,
            StartTime = act.StartTime,
            EndTime = act.EndTime
        };
        dialogOpen = true;
    }

    private async Task HandleActivitySave()
    {
        try
        {
            if (!isEditing)
            {
                var created = await ActivityService.CreateActivityAsync(new CreateActivityDto
                {
                    ModuleId = ModuleId,
                    Name = formModel.Name,
                    Description = formModel.Description,
                    ActivityTypeId = formModel.ActivityTypeId,
                    StartTime = formModel.StartTime ?? DateTime.Now,
                    EndTime = formModel.EndTime
                });

                if (created is not null)
                {
                    activities.Add(created);
                    successMessage = $"Activity '{created.Name}' created.";
                    dialogOpen = false;
                }
                else
                {
                    errorMessage = "Failed to create activity. Please try again.";
                }
            }
            else if (editingActivity is not null)
            {
                await ActivityService.UpdateActivityAsync(editingActivity.Id, new UpdateActivityDto
                {
                    Name = formModel.Name,
                    Description = formModel.Description,
                    ActivityTypeId = formModel.ActivityTypeId,
                    StartTime = formModel.StartTime ?? DateTime.Now,
                    EndTime = formModel.EndTime
                });

                dialogOpen = false;
                successMessage = $"Activity '{formModel.Name}' updated.";
                // Reload to get fresh data with updated type name etc.
                await LoadModuleAsync();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to save activity. {ex.Message}";
        }
    }

    // ---- Activity delete ----

    private void HandleDeleteActivity(ActivityDto act)
    {
        activityToDelete = act;
        showDeleteActivityConfirm = true;
    }

    private async Task ConfirmDeleteActivityAsync()
    {
        if (activityToDelete is null) return;

        isDeletingActivity = true;
        try
        {
            await ActivityService.DeleteActivityAsync(activityToDelete.Id);
            activities.RemoveAll(a => a.Id == activityToDelete.Id);
            successMessage = $"Activity '{activityToDelete.Name}' deleted.";
            activityToDelete = null;
            showDeleteActivityConfirm = false;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to delete activity. {ex.Message}";
            showDeleteActivityConfirm = false;
        }
        finally
        {
            isDeletingActivity = false;
        }
    }

    // ---- Activity Type dialog ----

    private void OpenActivityTypeDialog()
    {
        newActivityTypeName = string.Empty;
        newActivityTypeDescription = string.Empty;
        activityTypeError = null;
        activityTypeDialogOpen = true;
        // Note: we intentionally do NOT close dialogOpen here so that
        // ActivityTypeDialog stacks on top of ActivityDialog when triggered from within it.
    }

    private async Task HandleCreateActivityType()
    {
        activityTypeError = null;

        if (string.IsNullOrWhiteSpace(newActivityTypeName))
        {
            activityTypeError = "Please enter an activity type name.";
            return;
        }
        if (string.IsNullOrWhiteSpace(newActivityTypeDescription))
        {
            activityTypeError = "Please enter an activity type description.";
            return;
        }

        isCreatingActivityType = true;
        try
        {
            var created = await ActivityTypeService.CreateActivityTypeAsync(new CreateActivityTypeDto
            {
                Name = newActivityTypeName.Trim(),
                Description = newActivityTypeDescription
            });

            if (created is null)
            {
                activityTypeError = "Failed to create activity type.";
                return;
            }

            var typesResult = await ActivityTypeService.GetAllActivityTypesAsync();
            activityTypes = typesResult?.ToList() ?? [];

            // Pre-select the newly created type in the dialog form
            formModel.ActivityTypeId = created.Id;

            activityTypeDialogOpen = false;
            newActivityTypeName = string.Empty;
            newActivityTypeDescription = string.Empty;
        }
        catch (Exception ex)
        {
            activityTypeError = $"Failed to create activity type. {ex.Message}";
        }
        finally
        {
            isCreatingActivityType = false;
        }
    }

    private async Task HandleDeleteActivityType(int activityTypeId)
    {
        try
        {
            await ActivityTypeService.DeleteActivityTypeAsync(activityTypeId);
            var typesResult = await ActivityTypeService.GetAllActivityTypesAsync();
            activityTypes = typesResult?.ToList() ?? [];
            formModel.ActivityTypeId = 0;
        }
        catch (Exception ex)
        {
            activityTypeError = $"Cannot delete this activity type: {ex.Message}";
        }
    }

    // ---- Document actions ----
    private async Task SaveDocumentAsync()
    {
        var createdDocument = await DocumentService.CreateDocumentAsync(new CreateDocumentDto
        {
            ModuleId = ModuleId,
            Description = documentUpload.Description
        }, documentUpload);

        if(createdDocument is not null)
        {
            documents.Add(createdDocument);
            successMessage = $"Document '{createdDocument.DisplayName}' uploaded.";
            documentUpload = new UploadDocumentValue();
            showUploadDocument = false;
        }
        else
        {
            errorMessage = "Failed to upload document. Please try again.";
        }
    }

    private void HandleDeleteDocument(DocumentDto doc)
    {
        documentToDelete = doc;
        showDeleteDocumentConfirm = true;
    }

    private async Task ConfirmDeleteDocumentAsync()
    {
        if (documentToDelete is null) return;

        await DocumentService.DeleteDocumentAsync(documentToDelete.Id);
        documents.RemoveAll(d => d.Id == documentToDelete.Id);
        successMessage = $"Document '{documentToDelete.DisplayName}' was deleted.";
        documentToDelete = null;
        showDeleteDocumentConfirm = false;
        await Task.CompletedTask;
    }

    // ---- Helpers ----
    private void GoBack() => Navigation.NavigateTo($"/courses/{module!.CourseId}");

    // private string getURL(int activityId) => $"/admin/activities/{activityId}/details";
    private string getURL(int activityId) 
        => isTeacher ? $"/admin/activities/{activityId}/details" 
                     : $"/activities/{activityId}/details";

    public static class ActivityHelpers
    {
        public static string GetActivityTypeBadge(string? typeName) => typeName switch
        {
            "Assignment" => "bg-warning text-dark",
            "Exercise"   => "bg-danger",
            "Lecture"    => "bg-primary",
            "E-Learning" => "bg-success",
            _            => "bg-secondary"
        };
    }
}
